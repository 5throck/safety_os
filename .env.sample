# .env.sample — copy to .env and fill in values

# 국가법령정보센터 Open API OC 키
# 발급: https://www.law.go.kr/LSO/openApi/openApiOcPage.do
# MCP server: mcp_kr_legislation (get_current_law, get_law_amendments)
LAW_API_OC=your_oc_key_here

# GitHub Personal Access Token (no scopes required — public repo read only)
# 발급: https://github.com/settings/tokens
# MCP server: legalize_kr (search_precedent)
# 미설정 시 search_precedent 툴 비활성화
GITHUB_TOKEN=your_github_token_here
