#!/usr/bin/env bash
# pre-rebase hook - Scan commits being rebased for secrets
# Triggered: Before git rebase operation
# Blocks: Rebase if secrets detected in any commit being rewritten
# Bypass: Set REBASE_BYPASS_SECRET_SCAN=1 to disable (not recommended)

set -euo pipefail

# Allow bypass with environment variable (use carefully!)
if [ "${REBASE_BYPASS_SECRET_SCAN:-0}" = "1" ]; then
    echo "⚠️  WARNING: Secret scan bypassed via REBASE_BYPASS_SECRET_SCAN=1"
    exit 0
fi

# Check if gitleaks is available
if ! command -v gitleaks &> /dev/null; then
    echo "⚠️  gitleaks not found - skipping secret scan during rebase"
    echo "   Install gitleaks for protection: https://github.com/gitleaks/gitleaks"
    exit 0
fi

echo "🔍 Scanning for secrets in commits being rebased..."

# Get the range of commits being rebased
# $1 = upstream branch, $2 = branch being rebased
if [ $# -ge 2 ]; then
    UPSTREAM="$1"
    REBASE_BRANCH="$2"

    # Scan each commit in the rebase range
    git rev-list --no-merges "$UPSTREAM..$REBASE_BRANCH" | while read -r commit; do
        if git show "$commit" 2>/dev/null | gitleaks detect --no-git --verbose --exit-code 2>/dev/null; then
            echo "✅ Commit $commit: clean"
        else
            echo "❌ SECRET DETECTED in commit $commit"
            echo "   Rebase blocked to prevent secret exposure"
            echo ""
            echo "To bypass (not recommended):"
            echo "  REBASE_BYPASS_SECRET_SCAN=1 git rebase $UPSTREAM $REBASE_BRANCH"
            exit 1
        fi
    done
else
    # Fallback: scan recent commits if no parameters provided
    echo "⚠️  No rebase parameters - scanning last 10 commits"
    git log -n 10 --format="%H" | while read -r commit; do
        if git show "$commit" 2>/dev/null | gitleaks detect --no-git --verbose --exit-code 2>/dev/null; then
            echo "✅ Commit $commit: clean"
        else
            echo "❌ SECRET DETECTED in commit $commit"
            exit 1
        fi
    done
fi

echo "✅ No secrets found - rebase can proceed"
exit 0
