# Safety OS project settings
{
  "mcpServers": {
    "codegraph": {
      "command": "npx",
      "args": [
        "@colbymchenry/codegraph@0.9.7",
        "serve"
      ]
    },
    "korean-law": {
      "command": "npx",
      "args": [
        "-y",
        "korean-law-mcp@latest"
      ],
      "env": {
        "LAW_OC": "여기에_법제처_API_키_입력"
      }
    },
    "mcp-kr-legislation": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-kr-legislation"
      ]
    },
    "k-skill": {
      "command": "npx",
      "args": [
        "-y",
        "k-skill"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "git config core.hooksPath .githooks",
        "statusMessage": "Configuring git hooks..."
      }
    ]
  }
}
