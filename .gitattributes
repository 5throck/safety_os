# Auto detect text files and perform LF normalization
* text=auto

# All text files enforce LF (UTF-8 without BOM) — overrides core.autocrlf on checkout
*.md text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.c text eol=lf
*.h text eol=lf
*.mjs text eol=lf

# CRLF exceptions (Windows-native scripts)
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf
