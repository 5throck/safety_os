{
  "mcpServers": {
    "codegraph_search": {
      "command": "node",
      "args": ["../../node_modules/.bin/codegraph-mcp", "search"],
      "env": {}
    },
    "codegraph_mutate": {
      "command": "node",
      "args": ["../../node_modules/.bin/codegraph-mcp", "mutate"],
      "env": {}
    },
    "k_skill": {
      "command": "bun",
      "args": ["run", "./vendor/k-skill/index.ts"],
      "env": {}
    },
    "legalize_kr": {
      "command": "bun",
      "args": ["run", "./vendor/legalize-kr/index.ts"],
      "env": {}
    },
    "mcp_kr_legislation": {
      "command": "bun",
      "args": ["run", "./vendor/mcp-kr-legislation/index.ts"],
      "env": {}
    }
  }
}
