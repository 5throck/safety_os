{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "powergen-turbine-record.json",
  "title": "Power Plant Turbine and Generator Record",
  "description": "터빈/발전기 회전체 운영 및 정비 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "plant_type", "kesa_inspection_status", "voltage_class", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^PWRG-TRB-[0-9]{4}-[0-9]{4}$" },
    "plant_type": {
      "type": "string",
      "enum": ["thermal_coal", "thermal_LNG", "thermal_oil", "wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess"]
    },
    "kesa_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"],
      "description": "한국전기안전공사 (KESCO) 인증 상태"
    },
    "voltage_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "extra_high", "not_applicable"],
      "description": "low (≤400V) / medium (400V-22kV) / high (22-154kV) / extra_high (>154kV)"
    },
    "renewable_category": {
      "type": ["string", "null"],
      "enum": ["wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess", null]
    },
    "facility_id": { "type": "string" },
    "turbine_id": { "type": "string" },
    "turbine_type": { "type": "string", "enum": ["steam", "gas", "hydro", "wind"] },
    "rated_capacity_mw": { "type": "number" },
    "operating_rpm": { "type": "number" },
    "vibration_level_mms": { "type": "number", "description": "ISO 10816 vibration" },
    "vibration_alarm_threshold_mms": { "type": "number" },
    "bearing_temperature_c": { "type": "number" },
    "last_overhaul_date": { "type": "string", "format": "date" },
    "next_overhaul_due": { "type": "string", "format": "date" },
    "blades_inspected": { "type": "boolean" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
