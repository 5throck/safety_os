{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "powergen-high-voltage-record.json",
  "title": "Power Plant High Voltage Electrical Record",
  "description": "고압 전기 시스템 운영 및 작업 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "plant_type", "kesa_inspection_status", "voltage_class", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^PWRG-HV-[0-9]{4}-[0-9]{4}$" },
    "plant_type": {
      "type": "string",
      "enum": ["thermal_coal", "thermal_LNG", "thermal_oil", "wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess"]
    },
    "kesa_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"],
      "description": "한국전기안전공사 (KESCO) 인증 상태"
    },
    "voltage_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "extra_high", "not_applicable"],
      "description": "low (≤400V) / medium (400V-22kV) / high (22-154kV) / extra_high (>154kV)"
    },
    "renewable_category": {
      "type": ["string", "null"],
      "enum": ["wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess", null]
    },
    "facility_id": { "type": "string" },
    "system_id": { "type": "string" },
    "voltage_kv": { "type": "number" },
    "current_a": { "type": "number" },
    "arc_flash_boundary_m": { "type": "number", "description": "IEEE 1584 arc flash boundary" },
    "incident_energy_cal_cm2": { "type": "number", "description": "at working distance" },
    "ppe_category_required": { "type": "integer", "description": "NFPA 70E PPE Category 1-4" },
    "live_work_performed": { "type": "boolean" },
    "permit_to_work_ref": { "type": ["string", "null"] },
    "grounding_verified": { "type": "boolean" },
    "lockout_tagout_applied": { "type": "boolean" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
