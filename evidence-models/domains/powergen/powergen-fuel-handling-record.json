{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "powergen-fuel-handling-record.json",
  "title": "Power Plant Fuel Handling Record",
  "description": "발전소 연료 (석탄/LNG/오일) 취급 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "plant_type", "kesa_inspection_status", "voltage_class", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^PWRG-FUL-[0-9]{4}-[0-9]{4}$" },
    "plant_type": {
      "type": "string",
      "enum": ["thermal_coal", "thermal_LNG", "thermal_oil", "wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess"]
    },
    "kesa_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"],
      "description": "한국전기안전공사 (KESCO) 인증 상태"
    },
    "voltage_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "extra_high", "not_applicable"],
      "description": "low (≤400V) / medium (400V-22kV) / high (22-154kV) / extra_high (>154kV)"
    },
    "renewable_category": {
      "type": ["string", "null"],
      "enum": ["wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess", null]
    },
    "facility_id": { "type": "string" },
    "fuel_type": { "type": "string", "enum": ["coal", "LNG", "oil", "biomass"] },
    "fuel_storage_id": { "type": "string" },
    "quantity_received_tons": { "type": "number" },
    "supplier_id": { "type": "string" },
    "delivery_date": { "type": "string", "format": "date" },
    "quality_test_passed": { "type": "boolean" },
    "unloading_method": { "type": "string", "enum": ["conveyor", "pipeline", "truck", "ship"] },
    "dust_suppression_active": { "type": "boolean", "description": "석탄 비산 방지" },
    "msds_record_ref": { "type": ["string", "null"], "description": "화학물질인 경우" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
