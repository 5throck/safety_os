{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "powergen-waste-management-record.json",
  "title": "Power Plant Waste Management Record",
  "description": "화력 발전 폐기물 (석탄재/화학폐수) 관리.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "plant_type", "kesa_inspection_status", "voltage_class", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^PWRG-WST-[0-9]{4}-[0-9]{4}$" },
    "plant_type": {
      "type": "string",
      "enum": ["thermal_coal", "thermal_LNG", "thermal_oil", "wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess"]
    },
    "kesa_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"],
      "description": "한국전기안전공사 (KESCO) 인증 상태"
    },
    "voltage_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "extra_high", "not_applicable"],
      "description": "low (≤400V) / medium (400V-22kV) / high (22-154kV) / extra_high (>154kV)"
    },
    "renewable_category": {
      "type": ["string", "null"],
      "enum": ["wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess", null]
    },
    "facility_id": { "type": "string" },
    "waste_type": { "type": "string", "enum": ["coal_ash_bottom", "coal_ash_fly", "chemical_wastewater", "gypsum", "scrap_metal"] },
    "quantity_tons": { "type": "number" },
    "generation_date": { "type": "string", "format": "date" },
    "disposal_method": { "type": "string", "enum": ["recycling", "landfill", "cement_raw_material", "ocean_disposal", "incineration"] },
    "disposal_contractor_id": { "type": "string" },
    "manifest_number": { "type": "string", "description": "폐기물 관리 폐기물 인계서" },
    "environmental_report_filed": { "type": "boolean" },
    "heavy_metal_tested": { "type": "boolean", "description": "석탄재 중금속 분석" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
