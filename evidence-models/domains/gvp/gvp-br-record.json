{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gvp-br-record.json",
  "title": "GVP Benefit-Risk Record",
  "description": "Benefit-Risk Assessment per EU GVP Module 12.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "ich_e2_compliance", "pbrer_cycle_ref", "product_id", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GVP-BR-[0-9]{4}-[0-9]{4}$" },
    "ich_e2_compliance": {
      "type": "boolean",
      "description": "Compliant with relevant ICH E2 series guideline"
    },
    "pbrer_cycle_ref": {
      "type": ["string", "null"],
      "description": "PBRER cycle identifier (annual reporting cycle)"
    },
    "product_id": {
      "type": "string",
      "description": "Drug product identifier (GTIN or Korean product code)"
    },
    "rmp_version_ref": {
      "type": ["string", "null"],
      "description": "Risk Management Plan version reference (when applicable)"
    },
    "framework_used": { "type": "string", "enum": ["PrOACT_URL", "BRAT", "MCDA", "qualitative_narrative"] },
    "benefit_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": { "type": "string" },
          "weight": { "type": "number" },
          "score": { "type": "number" }
        }
      }
    },
    "risk_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": { "type": "string" },
          "weight": { "type": "number" },
          "score": { "type": "number" }
        }
      }
    },
    "integrated_br_score": { "type": "number" },
    "br_decision": { "type": "string", "enum": ["favorable", "favorable_with_monitoring", "uncertain", "unfavorable"] },
    "decision_rationale": { "type": "string" },
    "stakeholder_input": {
      "type": "object",
      "properties": {
        "patient_perspective": { "type": "string" },
        "clinician_perspective": { "type": "string" },
        "regulatory_perspective": { "type": "string" }
      }
    },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
