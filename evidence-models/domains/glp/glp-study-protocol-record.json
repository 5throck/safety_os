{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glp-study-protocol-record.json",
  "title": "GLP Study Protocol Record",
  "description": "Study protocol per OECD GLP Section 8.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "study_director_id", "glp_certification_authority", "oecd_mad_applicable", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GLP-SP-[0-9]{4}-[0-9]{4}$" },
    "study_director_id": {
      "type": "string",
      "description": "OECD GLP requires designated Study Director (Section 1.2)"
    },
    "glp_certification_authority": {
      "type": "string",
      "enum": ["MFDS", "ME", "both", "OECD_MAD_only"],
      "description": "Which authority's GLP certification applies"
    },
    "oecd_mad_applicable": {
      "type": "boolean",
      "description": "Whether data is eligible for OECD Mutual Acceptance of Data"
    },
    "msds_record_ref": {
      "type": ["string", "null"],
      "description": "MSDS record ID for test article (when applicable)"
    },
    "study_number": { "type": "string" },
    "study_title": { "type": "string" },
    "study_type": { "type": "string", "enum": ["acute_toxicity", "subchronic", "chronic", "carcinogenicity", "reproductive", "ecotoxicity", "safety_pharmacology", "other"] },
    "test_system": { "type": "string", "description": "Animal species/cell line" },
    "sponsor_id": { "type": "string" },
    "protocol_approval_date": { "type": "string", "format": "date-time" },
    "amendments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "amendment_id": { "type": "string" },
          "date": { "type": "string", "format": "date-time" },
          "rationale": { "type": "string" }
        }
      }
    },
    "deviations_count": { "type": "integer" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
