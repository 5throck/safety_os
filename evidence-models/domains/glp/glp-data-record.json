{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glp-data-record.json",
  "title": "GLP Raw Data Record (ALCOA+)",
  "description": "Raw data management per OECD GLP Section 9, 10.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "study_director_id", "glp_certification_authority", "oecd_mad_applicable", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GLP-DATA-[0-9]{4}-[0-9]{4}$" },
    "study_director_id": {
      "type": "string",
      "description": "OECD GLP requires designated Study Director (Section 1.2)"
    },
    "glp_certification_authority": {
      "type": "string",
      "enum": ["MFDS", "ME", "both", "OECD_MAD_only"],
      "description": "Which authority's GLP certification applies"
    },
    "oecd_mad_applicable": {
      "type": "boolean",
      "description": "Whether data is eligible for OECD Mutual Acceptance of Data"
    },
    "msds_record_ref": {
      "type": ["string", "null"],
      "description": "MSDS record ID for test article (when applicable)"
    },
    "study_number_ref": { "type": "string" },
    "data_type": { "type": "string", "enum": ["in_vivo", "in_vitro", "analytical", "clinical_chemistry", "pathology", "statistical"] },
    "raw_data_format": { "type": "string", "enum": ["electronic", "paper", "hybrid"] },
    "alcoa_compliance": {
      "type": "object",
      "properties": {
        "attributable": { "type": "boolean" },
        "legible": { "type": "boolean" },
        "contemporaneous": { "type": "boolean" },
        "original": { "type": "boolean" },
        "accurate": { "type": "boolean" },
        "complete": { "type": "boolean" },
        "consistent": { "type": "boolean" },
        "enduring": { "type": "boolean" },
        "available": { "type": "boolean" }
      }
    },
    "audit_trail_active": { "type": "boolean" },
    "retention_period_years": { "type": "integer", "default": 10 },
    "archive_location": { "type": "string" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
