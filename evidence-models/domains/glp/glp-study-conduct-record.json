{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glp-study-conduct-record.json",
  "title": "GLP Study Conduct Record",
  "description": "Study execution log per OECD GLP Section 9.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "study_director_id", "glp_certification_authority", "oecd_mad_applicable", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GLP-SC-[0-9]{4}-[0-9]{4}$" },
    "study_director_id": {
      "type": "string",
      "description": "OECD GLP requires designated Study Director (Section 1.2)"
    },
    "glp_certification_authority": {
      "type": "string",
      "enum": ["MFDS", "ME", "both", "OECD_MAD_only"],
      "description": "Which authority's GLP certification applies"
    },
    "oecd_mad_applicable": {
      "type": "boolean",
      "description": "Whether data is eligible for OECD Mutual Acceptance of Data"
    },
    "msds_record_ref": {
      "type": ["string", "null"],
      "description": "MSDS record ID for test article (when applicable)"
    },
    "study_number_ref": { "type": "string" },
    "study_start_date": { "type": "string", "format": "date-time" },
    "study_end_date": { "type": ["string", "null"], "format": "date-time" },
    "phases_completed": { "type": "array", "items": { "type": "string" } },
    "current_phase": { "type": "string" },
    "daily_log_refs": { "type": "array", "items": { "type": "string" } },
    "animal_usage": {
      "type": "object",
      "properties": {
        "species": { "type": "string" },
        "number_received": { "type": "integer" },
        "number_used": { "type": "integer" },
        "number_early_death": { "type": "integer" }
      }
    },
    "major_deviations": { "type": "integer" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
