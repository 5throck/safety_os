{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gmp-pqr-record.json",
  "title": "GMP Product Quality Review Record",
  "description": "Evidence model for GMP Product Quality Review (제품품질평가) records. v1 per KP-GMP 의약품등기준규정 Article 12 (PQR) + ICH Q7/Q10.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "product_code", "review_period", "conclusion", "legal_basis", "e_signature", "qrm_assessment", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GMP-PQR-[0-9]{4}-[0-9]{4}$"
    },
    "product_code": { "type": "string" },
    "product_name": { "type": "string" },
    "review_period": {
      "type": "object",
      "properties": {
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" }
      }
    },
    "data_sources": {
      "type": "object",
      "properties": {
        "batches_manufactured": { "type": "integer" },
        "batch_records_reviewed": { "type": "integer" },
        "deviation_count": { "type": "integer" },
        "capa_count": { "type": "integer" },
        "stability_studies": { "type": "integer" },
        "changes_implemented": { "type": "integer" },
        "supplier_count": { "type": "integer" },
        "complaints_count": { "type": "integer" },
        "returns_count": { "type": "integer" }
      }
    },
    "trend_analysis": {
      "type": "object",
      "properties": {
        "yield_trend": { "type": "string", "enum": ["stable", "improving", "declining"] },
        "deviation_trend": { "type": "string", "enum": ["stable", "improving", "declining"] },
        "complaint_trend": { "type": "string", "enum": ["stable", "improving", "declining"] },
        "oos_trend": { "type": "string", "enum": ["stable", "improving", "declining"] }
      }
    },
    "key_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "description": { "type": "string" },
          "capa_ref": { "type": "string", "pattern": "^GMP-CAPA-[0-9]{4}-[0-9]{4}$" }
        }
      }
    },
    "conclusion": {
      "type": "string",
      "enum": ["consistent_with_established_process", "improvement_required", "regulatory_action_recommended"]
    },
    "management_review_date": { "type": "string", "format": "date-time" },
    "next_pqr_due": { "type": "string", "format": "date" },
    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "qrm_assessment": { "$ref": "../../_shared/base/common.schema.json#/definitions/qrm_assessment" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
