{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gmp-equipment-qualification-record.json",
  "title": "GMP Equipment Qualification Record",
  "description": "Evidence model for GMP Equipment Qualification (설비 적격성평가) records. v1 per KP-GMP 의약품등기준규정 Article 16 + ICH Q7/Q10.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "equipment_id", "iq_oq_pq_status", "legal_basis", "e_signature", "qrm_assessment", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GMP-EQ-[0-9]{4}-[0-9]{4}$"
    },
    "equipment_id": { "type": "string" },
    "equipment_name": { "type": "string" },
    "location": { "type": "string" },
    "urs_ref": { "type": "string" },
    "dq": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "complete", "n/a"] },
        "completion_date": { "type": "string", "format": "date-time" }
      }
    },
    "iq": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "complete", "failed"] },
        "completion_date": { "type": "string", "format": "date-time" },
        "protocol_ref": { "type": "string" }
      }
    },
    "oq": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "complete", "failed"] },
        "completion_date": { "type": "string", "format": "date-time" },
        "protocol_ref": { "type": "string" }
      }
    },
    "pq": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "complete", "failed"] },
        "completion_date": { "type": "string", "format": "date-time" },
        "protocol_ref": { "type": "string" },
        "runs_completed": { "type": "integer", "minimum": 0 }
      }
    },
    "iq_oq_pq_status": {
      "type": "string",
      "enum": ["not_started", "in_progress", "qualified", "requalification_required"],
      "description": "Overall qualification status"
    },
    "calibration": {
      "type": "object",
      "properties": {
        "last_calibration": { "type": "string", "format": "date-time" },
        "calibration_due": { "type": "string", "format": "date-time" },
        "frequency": { "type": "string" }
      }
    },
    "preventive_maintenance": {
      "type": "object",
      "properties": {
        "last_pm": { "type": "string", "format": "date-time" },
        "next_pm_due": { "type": "string", "format": "date-time" }
      }
    },
    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "e_signature": { "$ref": "../../_shared/base/gmp-common.schema.json#/definitions/e_signature" },
    "qrm_assessment": { "$ref": "../../_shared/base/gmp-common.schema.json#/definitions/qrm_assessment" },
    "nomenclature": { "$ref": "../../_shared/base/gmp-common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/gmp-common.schema.json#/definitions/audit_trail" }
  }
}
