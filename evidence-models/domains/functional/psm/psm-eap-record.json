{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "psm-eap-record.json",
  "title": "PSM Emergency Action Plan Record",
  "description": "Evidence model for Emergency Action Plan (EAP) records per OSHA-KR Article 44.",
  "version": "1.0.0",
  "type": "object",
  "required": ["version", "record_id", "timestamp", "agent_id", "workflow_id", "legal_basis"],
  "properties": {
    "version": { "type": "string", "default": "1.0.0" },
    "record_id": { "type": "string", "pattern": "^PSM-EAP-[0-9]{4}-[0-9]{4}$" },
    "timestamp": { "type": "string", "format": "date-time", "description": "Timestamp when the record was created" },
    "agent_id": { "type": "string", "description": "ID of the agent that generated this record" },
    "workflow_id": { "type": "string", "description": "ID of the workflow execution" },
    "plan_version": { "type": "string" },
    "last_revision_date": { "type": "string", "format": "date" },
    "annual_drill_completed": { "type": "boolean" },
    "evacuation_routes_defined": { "type": "boolean" },
    "emergency_contacts": { "type": "array", "items": { "type": "string" } },
    "local_fire_dept_coordinated": { "type": "boolean" },
    "employee_training_completed": { "type": "boolean" },
    "legal_basis": { "type": "array", "items": { "type": "string" }, "minItems": 2, "description": "Legal basis for the EAP record (OSHA-KR Article 44)" }
  }
}
