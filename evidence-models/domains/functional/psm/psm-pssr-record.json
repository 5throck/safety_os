{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "psm-pssr-record.json",
  "title": "PSSR Record",
  "description": "Evidence model for Pre-Startup Safety Review (PSSR) records per OSHA-KR Article 44.",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of the evidence model",
      "default": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "pattern": "^PSM-PSSR-[0-9]{4}-[0-9]{4}$",
      "description": "Unique identifier for the PSSR record"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the record was created"
    },
    "agent_id": {
      "type": "string",
      "description": "ID of the agent that generated this record"
    },
    "workflow_id": {
      "type": "string",
      "description": "ID of the workflow execution"
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "description": "Multi-source legal basis"
    },
    "facility_or_equipment_id": {
      "type": "string",
      "description": "ID of the facility or equipment being reviewed"
    },
    "moc_reference": {
      "type": "string",
      "description": "Reference to the MOC record, if applicable"
    },
    "checklist_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "n/a"
            ]
          },
          "comments": {
            "type": "string"
          }
        },
        "required": [
          "item_id",
          "description",
          "status"
        ]
      }
    },
    "startup_approval": {
      "type": "object",
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "approved_by": {
          "type": "string"
        },
        "approval_date": {
          "type": "string",
          "format": "date-time"
        },
        "conditions": {
          "type": "string"
        }
      },
      "required": [
        "approved",
        "approved_by",
        "approval_date"
      ]
    }
  },
  "required": [
    "version",
    "record_id",
    "timestamp",
    "agent_id",
    "workflow_id",
    "legal_basis",
    "facility_or_equipment_id",
    "checklist_items",
    "startup_approval"
  ]
}
