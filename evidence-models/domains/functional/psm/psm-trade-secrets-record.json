{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "psm-trade-secrets-record.json",
  "title": "PSM Trade Secrets Record",
  "description": "영업비밀 관리 per OSHA PSM Element 14.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "legal_basis", "version"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^PSM-TS-[0-9]{4}-[0-9]{4}$" },
    "trade_secret_id": { "type": "string" },
    "chemical_or_process": { "type": "string" },
    "disclosure_agreements": { "type": "array", "items": { "type": "string" } },
    "employees_with_access": { "type": "integer" },
    "emergency_disclosure_plan": { "type": "boolean" },
    "last_review_date": { "type": "string", "format": "date" },

    "legal_basis": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
    "version": { "type": "string", "default": "1.0.0" }
  }
}
