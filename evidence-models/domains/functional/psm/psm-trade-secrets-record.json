{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "psm-trade-secrets-record.json",
  "title": "PSM Trade Secrets Record",
  "description": "Evidence model for PSM Trade Secrets management records per OSHA-KR Article 44.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "version",
    "record_id",
    "timestamp",
    "agent_id",
    "workflow_id",
    "legal_basis"
  ],
  "properties": {
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "pattern": "^PSM-TS-[0-9]{4}-[0-9]{4}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the record was created"
    },
    "agent_id": {
      "type": "string",
      "description": "ID of the agent that generated this record"
    },
    "workflow_id": {
      "type": "string",
      "description": "ID of the workflow execution"
    },
    "trade_secret_id": {
      "type": "string"
    },
    "chemical_or_process": {
      "type": "string"
    },
    "disclosure_agreements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "employees_with_access": {
      "type": "integer"
    },
    "emergency_disclosure_plan": {
      "type": "boolean"
    },
    "last_review_date": {
      "type": "string",
      "format": "date"
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "description": "Multi-source legal basis. Primary: OSHA-KR Article 44 (PSM — trade secrets). Adjacent laws may include: OSHA-KR Article 44 paragraph 7 (worker access to process safety information), SAPA Article 4 (right-to-know for worker safety).",
      "examples": [
        "산업안전보건법 Article 44 (공정안전관리 — 영업비밀 보호)",
        "산업안전보건법 Article 44 제7항 (근로자 정보열람권)"
      ]
    }
  }
}