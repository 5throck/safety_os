{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "psm-contractor-record.json",
  "title": "PSM Contractor Safety Record",
  "description": "Evidence model for PSM Contractor Safety records per OSHA-KR Article 44.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "version",
    "record_id",
    "contractor_id",
    "evaluation_score",
    "training_verification",
    "timestamp",
    "agent_id",
    "workflow_id",
    "legal_basis"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version.",
      "default": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "pattern": "^PSM-CTR-[0-9]{4}-[0-9]{4}$",
      "description": "Unique identifier for the contractor safety record"
    },
    "contractor_id": {
      "type": "string",
      "description": "ID of the contractor"
    },
    "evaluation_score": {
      "type": "number",
      "description": "Contractor safety evaluation score"
    },
    "training_verification": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "worker_id": {
            "type": "string",
            "description": "ID of the contractor worker"
          },
          "training_date": {
            "type": "string",
            "format": "date-time",
            "description": "Date training was completed"
          },
          "verified": {
            "type": "boolean",
            "description": "Whether training was verified"
          }
        },
        "required": [
          "worker_id",
          "training_date",
          "verified"
        ]
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the record was created"
    },
    "agent_id": {
      "type": "string",
      "description": "ID of the agent that generated this record"
    },
    "workflow_id": {
      "type": "string",
      "description": "ID of the workflow execution"
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "description": "Multi-source legal basis. Primary: OSHA-KR Article 44 (PSM — contractor safety). Adjacent laws may include: SAPA Article 5 (third-party/contractor safety duty), OSHA-KR Article 15-2 (contractor safety management), Occupational Safety and Health Standards Rule Article 92 (contractor LOTO training per KOSHA GUIDE Z-40-2022 section 7.4).",
      "examples": [
        "산업안전보건법 Article 44 (공정안전관리 — 도급인 안전관리)",
        "중대재해처벌법 Article 5 (제3자 및 도급 근로자 안전조치 의무)"
      ]
    }
  }
}