{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "psm-psi-record.json",
  "title": "PSM PSI Record",
  "description": "Evidence model for Process Safety Information (PSI) records per OSHA-KR Article 44.",
  "version": "1.0.0",
  "type": "object",
  "required": ["version", "record_id", "timestamp", "agent_id", "workflow_id", "legal_basis", "document_type", "document_version", "approval_history"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version.",
      "default": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "pattern": "^PSM-PSI-[0-9]{4}-[0-9]{4}$",
      "description": "Unique identifier for the PSI record"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the record was created"
    },
    "agent_id": {
      "type": "string",
      "description": "ID of the agent that generated this record"
    },
    "workflow_id": {
      "type": "string",
      "description": "ID of the workflow execution"
    },
    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "description": "Legal basis for the PSI record (OSHA-KR Article 44)"
    },
    "document_type": {
      "type": "string",
      "enum": ["p_and_id", "msds", "process_chemistry", "equipment_design", "other"],
      "description": "Type of PSI document"
    },
    "msds_identifier": {
      "type": "string",
      "description": "Reference to the associated MSDS record"
    },
    "document_version": {
      "type": "string",
      "description": "Version of the PSI document"
    },
    "approval_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "approver_role": {
            "type": "string",
            "description": "Role of the approver"
          },
          "approval_date": {
            "type": "string",
            "format": "date-time",
            "description": "Date of approval decision"
          },
          "status": {
            "type": "string",
            "enum": ["approved", "rejected", "pending"],
            "description": "Approval decision status"
          }
        },
        "required": ["approver_role", "approval_date", "status"]
      }
    }
  }
}
