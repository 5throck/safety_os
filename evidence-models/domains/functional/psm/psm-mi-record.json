{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "psm-mi-record.json",
  "title": "PSM MI Record",
  "description": "Evidence model for Mechanical Integrity (MI) inspection records per OSHA-KR Article 44.",
  "version": "1.0.0",
  "type": "object",
  "required": ["version", "record_id", "timestamp", "agent_id", "workflow_id", "legal_basis", "equipment_id", "inspection_date", "inspector_name", "status"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version.",
      "default": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "pattern": "^PSM-MI-[0-9]{4}-[0-9]{4}$",
      "description": "Unique identifier for the MI inspection record"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the record was created"
    },
    "agent_id": {
      "type": "string",
      "description": "ID of the agent that generated this record"
    },
    "workflow_id": {
      "type": "string",
      "description": "ID of the workflow execution"
    },
    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "description": "Legal basis for the MI record (OSHA-KR Article 44)"
    },
    "equipment_id": {
      "type": "string",
      "description": "ID of the inspected equipment"
    },
    "inspection_date": {
      "type": "string",
      "format": "date",
      "description": "Date of the inspection"
    },
    "inspector_name": {
      "type": "string",
      "description": "Name of the inspector"
    },
    "measurements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "parameter": {
            "type": "string",
            "description": "Measured parameter name"
          },
          "value": {
            "type": "number",
            "description": "Measured value"
          },
          "unit": {
            "type": "string",
            "description": "Unit of measurement"
          }
        },
        "required": ["parameter", "value", "unit"]
      }
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "conditional_pass"],
      "description": "Inspection result status"
    },
    "maintenance_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "maintenance_date": {
            "type": "string",
            "format": "date",
            "description": "Date maintenance was performed"
          },
          "description": {
            "type": "string",
            "description": "Description of maintenance performed"
          },
          "performed_by": {
            "type": "string",
            "description": "Person or team that performed the maintenance"
          }
        },
        "required": ["maintenance_date", "description", "performed_by"]
      }
    }
  }
}
