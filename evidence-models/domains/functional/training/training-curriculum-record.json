{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "training-curriculum-record.json",
  "title": "Training Curriculum Record",
  "description": "Training curriculum definition per OSHA-KR requirements.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "training_type", "title", "duration_hours", "target_audience", "legal_basis"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^TRAIN-CURR-[0-9]{4}-[0-9]{4}$" },
    "training_type": { "type": "string", "enum": ["regular", "special", "supervisor", "new_hire", "job_transfer", "first_aid", "msds"] },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "duration_hours": { "type": "number" },
    "target_audience": { "type": "array", "items": { "type": "string" } },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "module_id": { "type": "string" },
          "module_title": { "type": "string" },
          "duration_minutes": { "type": "number" },
          "content_type": { "type": "string", "enum": ["lecture", "video", "practical", "assessment", "case_study"] }
        }
      }
    },
    "assessment_required": { "type": "boolean" },
    "passing_score": { "type": ["number", "null"] },
    "refresh_cycle_months": { "type": "number", "description": "Retraining interval (12 = annual)" },
    "legal_basis": { "type": "array", "items": { "type": "string" }, "minItems": 2 }
  }
}
