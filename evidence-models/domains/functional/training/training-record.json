{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "training-record.json",
  "title": "Training Record",
  "description": "Safety training completion record per OSHA-KR Articles 13, 29, 31, 32, 114.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "training_type", "trainee_id", "completion_date", "hours_completed", "result", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^TRAIN-[A-Z]+-[0-9]{4}-[0-9]{4}$" },
    "training_type": {
      "type": "string",
      "enum": ["regular", "special", "supervisor", "new_hire", "job_transfer", "first_aid", "msds"],
      "description": "정기/특별/관리감독자/신규채용/직무전환/응급조치/MSDS"
    },
    "trainee_id": { "type": "string", "description": "Worker ID" },
    "trainee_name": { "type": "string" },
    "trainee_role": { "type": "string", "description": "Job title/role" },
    "completion_date": { "type": "string", "format": "date" },
    "hours_completed": { "type": "number", "description": "Training hours completed" },
    "required_hours": { "type": "number", "description": "Legally required minimum hours" },
    "result": { "type": "string", "enum": ["passed", "failed", "incomplete", "in_progress"] },
    "score": { "type": ["number", "null"], "description": "Test score (0-100) if applicable" },
    "instructor_id": { "type": "string" },
    "instructor_qualification_ref": { "type": ["string", "null"] },
    "curriculum_ref": { "type": "string", "description": "Reference to training-curriculum-record.json" },
    "industry_specific": { "type": ["string", "null"], "description": "If industry-specific (e.g., construction TBM)" },
    "next_training_due": { "type": "string", "format": "date" },
    "retraining_required": { "type": "boolean" },
    "training_location": { "type": "string" },
    "training_method": { "type": "string", "enum": ["classroom", "online", "on_the_job", "field", "vr_ar"] },
    "legal_basis": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
