{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "instructor-qualification-record.json",
  "title": "Instructor Qualification Record",
  "description": "Safety training instructor qualification per KOSHA requirements.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "instructor_id",
    "name",
    "qualification_type",
    "valid_until",
    "legal_basis"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^TRAIN-INST-[0-9]{4}-[0-9]{4}$"
    },
    "instructor_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "qualification_type": {
      "type": "string",
      "enum": [
        "kosha_certified",
        "internal_qualified",
        "external_expert",
        "safety_manager"
      ]
    },
    "qualification_number": {
      "type": "string"
    },
    "qualified_training_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "regular",
          "special",
          "supervisor",
          "new_hire",
          "first_aid",
          "msds"
        ]
      }
    },
    "valid_from": {
      "type": "string",
      "format": "date"
    },
    "valid_until": {
      "type": "string",
      "format": "date"
    },
    "renewal_required": {
      "type": "boolean"
    },
    "legal_basis": {
      "type": "array",
      "description": "Multi-source legal basis. Primary: OSHA-KR Article 29 §4 (instructor qualification requirements for safety education) or Article 31 §3 (instructor requirements for special safety education). Adjacent laws may include: SAPA Article 7 (employer must ensure qualified instructors — quality of training provision), KOSHA qualification standards (안전보건교육 강사 자격 기준).",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "examples": [
        ["OSHA-KR Art.29 §4", "KOSHA GUIDE T-XX-2022", "SAPA Art.7"],
        ["OSHA-KR Art.31 §3", "KOSHA GUIDE T-XX-2022", "SAPA Art.7"],
        ["OSHA-KR Art.29 §4", "OSHA-KR Art.32 §2", "SAPA Art.7"]
      ]
    }
  }
}
