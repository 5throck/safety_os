{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "instructor-qualification-record.json",
  "title": "Instructor Qualification Record",
  "description": "Safety training instructor qualification per KOSHA requirements.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "instructor_id", "name", "qualification_type", "valid_until", "legal_basis"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^TRAIN-INST-[0-9]{4}-[0-9]{4}$" },
    "instructor_id": { "type": "string" },
    "name": { "type": "string" },
    "qualification_type": { "type": "string", "enum": ["kosha_certified", "internal_qualified", "external_expert", "safety_manager"] },
    "qualification_number": { "type": "string" },
    "qualified_training_types": { "type": "array", "items": { "type": "string", "enum": ["regular", "special", "supervisor", "new_hire", "first_aid", "msds"] } },
    "valid_from": { "type": "string", "format": "date" },
    "valid_until": { "type": "string", "format": "date" },
    "renewal_required": { "type": "boolean" },
    "legal_basis": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  }
}
