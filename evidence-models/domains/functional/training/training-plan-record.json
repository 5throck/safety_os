{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "training-plan-record.json",
  "title": "Training Plan Record",
  "description": "Annual/quarterly training plan per OSHA-KR.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "plan_year", "plan_type", "target_headcount", "legal_basis"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^TRAIN-PLAN-[0-9]{4}-[0-9]{4}$" },
    "plan_year": { "type": "integer" },
    "plan_type": { "type": "string", "enum": ["annual", "quarterly", "monthly", "project_based"] },
    "target_headcount": { "type": "integer" },
    "planned_sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "session_id": { "type": "string" },
          "training_type": { "type": "string" },
          "scheduled_month": { "type": "string" },
          "target_count": { "type": "integer" },
          "instructor_id": { "type": "string" }
        }
      }
    },
    "budget_krw": { "type": ["number", "null"] },
    "approved_by": { "type": "string" },
    "legal_basis": {
      "type": "array",
      "description": "Multi-source legal basis. Primary: OSHA-KR Article 29 (training plan establishment obligation). Adjacent laws may include: SAPA Article 7 (employer obligation to establish training program), SAPA Article 8 (safety and health management system — includes training planning), OSHA-KR Article 31 (special education planning for hazardous work).",
      "items": { "type": "string" },
      "minItems": 3,
      "examples": [
        ["OSHA-KR Art.29 §1", "SAPA Art.7", "SAPA Art.8"],
        ["OSHA-KR Art.29 §1", "OSHA-KR Art.31 §1", "SAPA Art.7"],
        ["OSHA-KR Art.29 §1", "OSHA-KR Art.32 §1", "SAPA Art.7"]
      ]
    }
  }
}
