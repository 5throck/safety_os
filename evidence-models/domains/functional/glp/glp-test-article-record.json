{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glp-test-article-record.json",
  "title": "GLP Test Article Record",
  "description": "Test article lifecycle record per OECD GLP Section 7.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "study_director_id", "glp_certification_authority", "oecd_mad_applicable", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GLP-TA-[0-9]{4}-[0-9]{4}$" },
    "study_director_id": {
      "type": "string",
      "description": "OECD GLP requires designated Study Director (Section 1.2)"
    },
    "glp_certification_authority": {
      "type": "string",
      "enum": ["MFDS", "ME", "both", "OECD_MAD_only"],
      "description": "Which authority's GLP certification applies"
    },
    "oecd_mad_applicable": {
      "type": "boolean",
      "description": "Whether data is eligible for OECD Mutual Acceptance of Data"
    },
    "msds_record_ref": {
      "type": ["string", "null"],
      "description": "MSDS record ID for test article (when applicable)"
    },
    "test_article_name": { "type": "string" },
    "cas_number": { "type": ["string", "null"] },
    "lot_batch_number": { "type": "string" },
    "purity_pct": { "type": "number" },
    "physical_state": { "type": "string", "enum": ["solid", "liquid", "gas", "mixture"] },
    "storage_conditions": { "type": "string" },
    "receipt_date": { "type": "string", "format": "date-time" },
    "expiration_date": { "type": ["string", "null"], "format": "date" },
    "retention_sample_required": { "type": "boolean" },
    "disposition": { "type": "string", "enum": ["in_use", "retained", "disposed"] },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
