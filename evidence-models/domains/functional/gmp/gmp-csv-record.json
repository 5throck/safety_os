{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gmp-csv-record.json",
  "title": "GMP Computer System Validation Record",
  "description": "Evidence model for GMP Computer System Validation (컴퓨터 시스템 적합성평가) records. v1 per KP-GMP 의약품등기준규정 Article 17 + 21 CFR Part 11 + GAMP 5.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "system_id", "gxp_category", "validation_level", "audit_trail_review", "legal_basis", "e_signature", "qrm_assessment", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GMP-CSV-[0-9]{4}-[0-9]{4}$"
    },
    "system_id": { "type": "string" },
    "system_name": { "type": "string" },
    "system_owner": { "type": "string" },
    "gxp_category": {
      "type": "string",
      "enum": ["gxp_critical", "gxp_indirect", "no_impact"]
    },
    "gamp5_category": {
      "type": "string",
      "enum": ["1", "3", "4", "5"]
    },
    "validation_level": {
      "type": "string",
      "enum": ["supplier_audit_only", "installation_verification", "full_validation"]
    },
    "urs_ref": { "type": "string" },
    "dq_status": { "type": "string", "enum": ["pending", "complete", "n/a"] },
    "iq_status": { "type": "string", "enum": ["pending", "complete", "failed"] },
    "oq_status": { "type": "string", "enum": ["pending", "complete", "failed"] },
    "pq_status": { "type": "string", "enum": ["pending", "complete", "failed"] },
    "data_integrity": {
      "type": "object",
      "properties": {
        "alcoa_compliance": { "type": "boolean" },
        "audit_trail_enabled": { "type": "boolean" },
        "audit_trail_review": { "type": "string", "enum": ["enabled", "reviewed", "failed"] },
        "unique_user_accounts": { "type": "boolean" },
        "password_policy_enforced": { "type": "boolean" }
      }
    },
    "electronic_signature": {
      "type": "object",
      "properties": {
        "schema_implemented": { "type": "boolean" },
        "cryptographic_implementation": { "type": "boolean", "description": "v1: false. v2: PKI/HSM." }
      }
    },
    "periodic_review_due": { "type": "string", "format": "date-time" },
    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "qrm_assessment": { "$ref": "../../../_shared/base/common.schema.json#/definitions/qrm_assessment" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
