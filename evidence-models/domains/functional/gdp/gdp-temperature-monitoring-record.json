{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gdp-temperature-monitoring-record.json",
  "title": "GDP Temperature Monitoring Record",
  "description": "Time-series temperature data for storage and transit per KGDP cold chain requirements.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "legal_basis", "gdp_certification_status", "temperature_condition", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GDP-TM-[0-9]{4}-[0-9]{4}$" },
    "gdp_certification_status": {
      "type": "string",
      "enum": ["certified", "pending", "suspended", "expired"],
      "description": "KGDP certification status at time of record"
    },
    "temperature_condition": {
      "type": "string",
      "enum": ["cold_chain_2_8C", "frozen_below_minus_15C", "controlled_room_15_25C", "ambient_30C_max", "not_applicable"]
    },
    "batch_disposition_approved_ref": {
      "type": ["string", "null"],
      "description": "GMP batch-record ID (for goods receipt from manufacturing)"
    },
    "monitoring_location": { "type": "string" },
    "sensor_id": { "type": "string" },
    "calibration_due": { "type": "string", "format": "date" },
    "spec_range_min_c": { "type": "number" },
    "spec_range_max_c": { "type": "number" },
    "time_series_data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "temp_c": { "type": "number" },
          "humidity_pct": { "type": ["number", "null"] }
        }
      }
    },
    "excursion_events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time" },
          "duration_minutes": { "type": "number" },
          "max_deviation_c": { "type": "number" },
          "impact_assessment": { "type": "string", "enum": ["no_impact", "use_as_is", "quarantine", "destroy"] }
        }
      }
    },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
