{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gasterm-pipe-transfer-record.json",
  "title": "Gas Pipe Transfer Record",
  "description": "배관 이송 작업 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "facility_type", "kgs_inspection_status", "psm_applicable", "gas_type", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GTRM-PIPE-[0-9]{4}-[0-9]{4}$" },
    "facility_type": {
      "type": "string",
      "enum": ["LNG_terminal", "LPG_charging", "hydrogen_charging", "city_gas_storage", "pipe_transfer"]
    },
    "kgs_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"]
    },
    "psm_applicable": {
      "type": "boolean",
      "description": "대규모 가스터미널 PSM 적용 여부"
    },
    "gas_type": {
      "type": "string",
      "enum": ["LNG", "LPG", "hydrogen", "natural_gas", "other"]
    },
    "facility_id": { "type": "string" },
    "pipeline_id": { "type": "string" },
    "pipeline_segment": { "type": "string" },
    "transfer_start": { "type": "string", "format": "date-time" },
    "transfer_end": { "type": "string", "format": "date-time" },
    "volume_transferred_m3": { "type": "number" },
    "pressure_differential_bar": { "type": "number" },
    "cathodic_protection_status": { "type": "string", "enum": ["active", "fault", "maintenance"] },
    "leak_test_conducted": { "type": "boolean" },
    "pigging_completed": { "type": "boolean", "description": "정기 pigging" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
