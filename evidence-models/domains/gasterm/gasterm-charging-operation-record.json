{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gasterm-charging-operation-record.json",
  "title": "Gas Charging Operation Record",
  "description": "LPG/수소 충전 작업 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "facility_type", "kgs_inspection_status", "psm_applicable", "gas_type", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GTRM-CHG-[0-9]{4}-[0-9]{4}$" },
    "facility_type": {
      "type": "string",
      "enum": ["LNG_terminal", "LPG_charging", "hydrogen_charging", "city_gas_storage", "pipe_transfer"]
    },
    "kgs_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"]
    },
    "psm_applicable": {
      "type": "boolean",
      "description": "대규모 가스터미널 PSM 적용 여부"
    },
    "gas_type": {
      "type": "string",
      "enum": ["LNG", "LPG", "hydrogen", "natural_gas", "other"]
    },
    "facility_id": { "type": "string" },
    "charging_station_id": { "type": "string" },
    "vehicle_or_cylinder_id": { "type": "string" },
    "charging_start": { "type": "string", "format": "date-time" },
    "charging_end": { "type": "string", "format": "date-time" },
    "quantity_charged_kg": { "type": "number" },
    "pressure_at_completion_bar": { "type": "number" },
    "operator_id": { "type": "string" },
    "pre_charging_inspection_completed": { "type": "boolean" },
    "grounding_verified": { "type": "boolean" },
    "emergency_stop_tested": { "type": "boolean" },
    "leak_test_passed": { "type": "boolean" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
