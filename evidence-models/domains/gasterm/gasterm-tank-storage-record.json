{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gasterm-tank-storage-record.json",
  "title": "Gas Terminal Tank Storage Record",
  "description": "LNG/LPG/수소 저장탱크 운영 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "facility_type", "kgs_inspection_status", "psm_applicable", "gas_type", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GTRM-TANK-[0-9]{4}-[0-9]{4}$" },
    "facility_type": {
      "type": "string",
      "enum": ["LNG_terminal", "LPG_charging", "hydrogen_charging", "city_gas_storage", "pipe_transfer"]
    },
    "kgs_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"]
    },
    "psm_applicable": {
      "type": "boolean",
      "description": "대규모 가스터미널 PSM 적용 여부"
    },
    "gas_type": {
      "type": "string",
      "enum": ["LNG", "LPG", "hydrogen", "natural_gas", "other"]
    },
    "facility_id": { "type": "string" },
    "tank_id": { "type": "string" },
    "tank_capacity_m3": { "type": "number" },
    "design_pressure_bar": { "type": "number" },
    "operating_pressure_bar": { "type": "number" },
    "fill_level_pct": { "type": "number" },
    "temperature_c": { "type": "number" },
    "last_hydrotest_date": { "type": "string", "format": "date" },
    "next_hydrotest_due": { "type": "string", "format": "date" },
    "safety_relief_valve_count": { "type": "integer" },
    "anomalies_detected": { "type": "array", "items": { "type": "string" } },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
