{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kreach-registration-record.json",
  "title": "K-REACH Registration Record",
  "description": "Evidence model for K-REACH chemical registration records per K-REACH Articles 10-14.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "substance_id", "registration_type", "status", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^MSDS-KR-[0-9]{4}-[0-9]{4}$" },
    "substance_id": { "type": "string" },
    "substance_name": { "type": "string" },
    "cas_number": { "type": "string" },
    "registration_type": {
      "type": "string",
      "enum": ["new_chemical_pre_registration", "existing_chemical_annual_report", "hazardous_concern_substance", "trade_secret_claim"]
    },
    "registration_number_me": { "type": ["string", "null"] },
    "annual_tonnage_ton": { "type": "number" },
    "submission_date": { "type": "string", "format": "date-time" },
    "approval_date": { "type": ["string", "null"], "format": "date-time" },
    "lead_time_days": { "type": "integer", "description": "Days between submission and approval (new chemical target: 90)" },
    "status": {
      "type": "string",
      "enum": ["draft", "submitted", "under_review", "approved", "approved_with_conditions", "rejected", "expired"]
    },
    "conditions": { "type": "array", "items": { "type": "string" } },
    "risk_management_measures": { "type": "string" },
    "trade_secret": {
      "type": "object",
      "properties": {
        "cbi_claim_filed": { "type": "boolean" },
        "cbi_approval_date": { "type": ["string", "null"], "format": "date" },
        "limited_disclosure_plan": { "type": "string" }
      }
    },
    "expiry_date": { "type": ["string", "null"], "format": "date" },
    "renewal_required": { "type": "boolean" },
    "ghs_version": {
      "type": "string",
      "enum": ["rev8", "rev9", "rev10"]
    },
    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
