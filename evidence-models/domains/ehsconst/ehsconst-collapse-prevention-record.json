{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ehsconst-collapse-prevention-record.json",
  "title": "Construction Collapse Prevention Record",
  "description": "붕괴 방지 조치 기록 (거푸집/굴착/가설구조).",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "sapa_article_12_compliance", "project_id", "contractor_tier", "safety_officer_in_charge", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^EHSC-COLL-[0-9]{4}-[0-9]{4}$" },
    "sapa_article_12_compliance": {
      "type": "boolean",
      "description": "중대재해처벌법 Article 12 (건설업 특례) 준수"
    },
    "project_id": {
      "type": "string",
      "description": "건설공사 번호 (Construction project number)"
    },
    "contractor_tier": {
      "type": "string",
      "enum": ["ordering_party", "prime_contractor", "first_subcontractor", "second_subcontractor_below"],
      "description": "발주처/원도급/1차 하도급/2차 이하"
    },
    "safety_officer_in_charge": {
      "type": "string",
      "description": "안전관리자 ID"
    },
    "structure_type": { "type": "string", "enum": ["formwork", "excavation", "scaffolding", "shoring", "temporary_structure", "tower_crane"] },
    "design_review_completed": { "type": "boolean" },
    "material_certification_verified": { "type": "boolean" },
    "installation_inspection_date": { "type": "string", "format": "date-time" },
    "structural_calculations_ref": { "type": "string" },
    "environmental_monitoring": {
      "type": "object",
      "properties": {
        "groundwater_level_monitored": { "type": "boolean" },
        "soil_condition_checked": { "type": "boolean" },
        "vibration_monitored": { "type": "boolean" },
        "displacement_measured": { "type": "boolean" }
      }
    },
    "last_inspection_findings": { "type": "string" },
    "work_suspended": { "type": "boolean" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
