{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ehsconst-inspection-record.json",
  "title": "Construction Daily Safety Inspection Record",
  "description": "일일/주간 안전점검 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "sapa_article_12_compliance", "project_id", "contractor_tier", "safety_officer_in_charge", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^EHSC-INSP-[0-9]{4}-[0-9]{4}$" },
    "sapa_article_12_compliance": {
      "type": "boolean",
      "description": "중대재해처벌법 Article 12 (건설업 특례) 준수"
    },
    "project_id": {
      "type": "string",
      "description": "건설공사 번호 (Construction project number)"
    },
    "contractor_tier": {
      "type": "string",
      "enum": ["ordering_party", "prime_contractor", "first_subcontractor", "second_subcontractor_below"],
      "description": "발주처/원도급/1차 하도급/2차 이하"
    },
    "safety_officer_in_charge": {
      "type": "string",
      "description": "안전관리자 ID"
    },
    "inspection_type": { "type": "string", "enum": ["daily_pre_work", "daily_during_work", "weekly", "monthly", "for_cause"] },
    "inspection_date": { "type": "string", "format": "date-time" },
    "inspector_id": { "type": "string" },
    "weather_conditions": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "string" },
          "category": { "type": "string", "enum": ["fall", "collapse", "electrical", "fire", "mechanical", "chemical", "other"] },
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "location": { "type": "string" },
          "description": { "type": "string" },
          "immediate_action": { "type": "string" },
          "corrective_action": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "in_progress", "closed"] }
        }
      }
    },
    "photographic_evidence": { "type": "array", "items": { "type": "string" } },
    "work_suspended": { "type": "boolean" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
