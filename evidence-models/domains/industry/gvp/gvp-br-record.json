{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gvp-br-record.json",
  "title": "GVP Benefit-Risk Record",
  "description": "Benefit-Risk Assessment per EU GVP Module 12.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "ich_e2_compliance",
    "pbrer_cycle_ref",
    "product_id",
    "legal_basis",
    "e_signature",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GVP-BR-[0-9]{4}-[0-9]{4}$"
    },
    "ich_e2_compliance": {
      "type": "boolean",
      "description": "Compliant with relevant ICH E2 series guideline"
    },
    "pbrer_cycle_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "PBRER cycle identifier (annual reporting cycle)"
    },
    "product_id": {
      "type": "string",
      "description": "Drug product identifier (GTIN or Korean product code)"
    },
    "rmp_version_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "Risk Management Plan version reference (when applicable)"
    },
    "framework_used": {
      "type": "string",
      "enum": [
        "PrOACT_URL",
        "BRAT",
        "MCDA",
        "qualitative_narrative"
      ]
    },
    "benefit_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "score": {
            "type": "number"
          }
        }
      }
    },
    "risk_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "score": {
            "type": "number"
          }
        }
      }
    },
    "integrated_br_score": {
      "type": "number"
    },
    "br_decision": {
      "type": "string",
      "enum": [
        "favorable",
        "favorable_with_monitoring",
        "uncertain",
        "unfavorable"
      ]
    },
    "decision_rationale": {
      "type": "string"
    },
    "stakeholder_input": {
      "type": "object",
      "properties": {
        "patient_perspective": {
          "type": "string"
        },
        "clinician_perspective": {
          "type": "string"
        },
        "regulatory_perspective": {
          "type": "string"
        }
      }
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "Multi-source legal basis. Primary: 약사법 Article 73의2 (mandatory ADR reporting) and Article 73의3 (re-evaluation). Adjacent laws may include: 의약품 이상반응 보고 규정 (MFDS KGVP standards), ICH E2 series (clinical safety data management), EU GVP Modules (pharmacovigilance processes).",
      "examples": [
        [
          "약사법 Art.73의2",
          "KGVP 규정",
          "ICH E2A"
        ],
        [
          "약사법 Art.73의3",
          "EU GVP Module IX",
          "ICH E2E"
        ],
        [
          "약사법 Art.73의2",
          "KGVP 규정",
          "ICH E2B(R3)"
        ]
      ]
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
