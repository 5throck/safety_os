{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gvp-icsr-record.json",
  "title": "GVP ICSR Record",
  "description": "Individual Case Safety Report per ICH E2B(R3).",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "ich_e2_compliance",
    "pbrer_cycle_ref",
    "product_id",
    "legal_basis",
    "e_signature",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GVP-ICSR-[0-9]{4}-[0-9]{4}$"
    },
    "ich_e2_compliance": {
      "type": "boolean",
      "description": "Compliant with relevant ICH E2 series guideline"
    },
    "pbrer_cycle_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "PBRER cycle identifier (annual reporting cycle)"
    },
    "product_id": {
      "type": "string",
      "description": "Drug product identifier (GTIN or Korean product code)"
    },
    "rmp_version_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "Risk Management Plan version reference (when applicable)"
    },
    "icsr_id_worldwide": {
      "type": "string",
      "description": "Global unique ICSR ID"
    },
    "reporter_type": {
      "type": "string",
      "enum": [
        "healthcare_professional",
        "patient",
        "literature",
        "foreign_authority",
        "clinical_trial",
        "other"
      ]
    },
    "patient_age": {
      "type": [
        "integer",
        "null"
      ]
    },
    "patient_sex": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "male",
        "female",
        "unknown"
      ]
    },
    "adverse_event_term_meddra_pt": {
      "type": "string"
    },
    "seriousness_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "death",
          "life_threatening",
          "hospitalization",
          "disability",
          "congenital_anomaly",
          "other_serious"
        ]
      }
    },
    "causality_who_umc": {
      "type": "string",
      "enum": [
        "certain",
        "probable",
        "possible",
        "unlikely",
        "conditional",
        "unassessable"
      ]
    },
    "onset_date": {
      "type": "string",
      "format": "date"
    },
    "report_received_date": {
      "type": "string",
      "format": "date-time"
    },
    "mfds_submission_due_date": {
      "type": "string",
      "format": "date-time"
    },
    "mfds_submission_actual_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "recovered",
        "recovering",
        "not_recovered",
        "fatal",
        "unknown"
      ]
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "Multi-source legal basis. Primary: 약사법 Article 73의2 (mandatory ADR reporting) and Article 73의3 (re-evaluation). Adjacent laws may include: 의약품 이상반응 보고 규정 (MFDS KGVP standards), ICH E2 series (clinical safety data management), EU GVP Modules (pharmacovigilance processes).",
      "examples": [
        [
          "약사법 Art.73의2",
          "KGVP 규정",
          "ICH E2A"
        ],
        [
          "약사법 Art.73의3",
          "EU GVP Module IX",
          "ICH E2E"
        ],
        [
          "약사법 Art.73의2",
          "KGVP 규정",
          "ICH E2B(R3)"
        ]
      ]
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
