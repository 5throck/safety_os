{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gvp-rmp-record.json",
  "title": "GVP RMP Record",
  "description": "Risk Management Plan per ICH E2E and EU GVP Module 5.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "ich_e2_compliance",
    "pbrer_cycle_ref",
    "product_id",
    "legal_basis",
    "e_signature",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GVP-RMP-[0-9]{4}-[0-9]{4}$"
    },
    "ich_e2_compliance": {
      "type": "boolean",
      "description": "Compliant with relevant ICH E2 series guideline"
    },
    "pbrer_cycle_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "PBRER cycle identifier (annual reporting cycle)"
    },
    "product_id": {
      "type": "string",
      "description": "Drug product identifier (GTIN or Korean product code)"
    },
    "rmp_version_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "Risk Management Plan version reference (when applicable)"
    },
    "rmp_version": {
      "type": "string"
    },
    "last_revision_date": {
      "type": "string",
      "format": "date"
    },
    "important_identified_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "important_potential_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_information": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routine_pv": {
      "type": "boolean"
    },
    "additional_pv_activities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "additional_risk_minimization": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "measure": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "educational_material",
              "dhcp_letter",
              "controlled_access",
              "patient_card",
              "other"
            ]
          },
          "implementation_date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "next_revision_due": {
      "type": "string",
      "format": "date"
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "Multi-source legal basis. Primary: 약사법 Article 73의2 (mandatory ADR reporting) and Article 73의3 (re-evaluation). Adjacent laws may include: 의약품 이상반응 보고 규정 (MFDS KGVP standards), ICH E2 series (clinical safety data management), EU GVP Modules (pharmacovigilance processes).",
      "examples": [
        [
          "약사법 Art.73의2",
          "KGVP 규정",
          "ICH E2A"
        ],
        [
          "약사법 Art.73의3",
          "EU GVP Module IX",
          "ICH E2E"
        ],
        [
          "약사법 Art.73의2",
          "KGVP 규정",
          "ICH E2B(R3)"
        ]
      ]
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
