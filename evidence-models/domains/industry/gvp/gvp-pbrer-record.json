{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gvp-pbrer-record.json",
  "title": "GVP PBRER Record",
  "description": "Periodic Benefit-Risk Evaluation Report per ICH E2C(R2).",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "ich_e2_compliance", "pbrer_cycle_ref", "product_id", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GVP-PBRER-[0-9]{4}-[0-9]{4}$" },
    "ich_e2_compliance": {
      "type": "boolean",
      "description": "Compliant with relevant ICH E2 series guideline"
    },
    "pbrer_cycle_ref": {
      "type": ["string", "null"],
      "description": "PBRER cycle identifier (annual reporting cycle)"
    },
    "product_id": {
      "type": "string",
      "description": "Drug product identifier (GTIN or Korean product code)"
    },
    "rmp_version_ref": {
      "type": ["string", "null"],
      "description": "Risk Management Plan version reference (when applicable)"
    },
    "reporting_period_start": { "type": "string", "format": "date" },
    "reporting_period_end": { "type": "string", "format": "date" },
    "report_version": { "type": "string" },
    "icsrs_in_period": { "type": "integer" },
    "serious_reactions_in_period": { "type": "integer" },
    "new_signals_in_period": { "type": "integer" },
    "ongoing_signals_count": { "type": "integer" },
    "closed_signals_count": { "type": "integer" },
    "benefit_assessment_summary": { "type": "string" },
    "risk_assessment_summary": { "type": "string" },
    "integrated_br_decision": { "type": "string", "enum": ["favorable", "favorable_with_monitoring", "uncertain", "unfavorable"] },
    "mfds_submission_date": { "type": ["string", "null"], "format": "date-time" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
