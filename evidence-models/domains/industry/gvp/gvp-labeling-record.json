{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gvp-labeling-record.json",
  "title": "GVP Safety Labeling Update Record",
  "description": "Safety labeling changes per EU GVP Module 15.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "ich_e2_compliance",
    "pbrer_cycle_ref",
    "product_id",
    "legal_basis",
    "e_signature",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GVP-LBL-[0-9]{4}-[0-9]{4}$"
    },
    "ich_e2_compliance": {
      "type": "boolean",
      "description": "Compliant with relevant ICH E2 series guideline"
    },
    "pbrer_cycle_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "PBRER cycle identifier (annual reporting cycle)"
    },
    "product_id": {
      "type": "string",
      "description": "Drug product identifier (GTIN or Korean product code)"
    },
    "rmp_version_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "Risk Management Plan version reference (when applicable)"
    },
    "labeling_section": {
      "type": "string",
      "enum": [
        "contraindications",
        "warnings_precautions",
        "adverse_reactions",
        "special_populations",
        "drug_interactions",
        "overdose",
        "other"
      ]
    },
    "change_type": {
      "type": "string",
      "enum": [
        "new_contraindication",
        "new_warning",
        "frequency_update",
        "severity_update",
        "special_population",
        "interaction"
      ]
    },
    "previous_text": {
      "type": [
        "string",
        "null"
      ]
    },
    "new_text": {
      "type": "string"
    },
    "change_rationale": {
      "type": "string"
    },
    "supporting_data_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_review_completed": {
      "type": "boolean"
    },
    "mfds_submission_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "mfds_approval_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "implementation_status": {
      "type": "string",
      "enum": [
        "pending_review",
        "submitted",
        "approved",
        "distributed",
        "rejected"
      ]
    },
    "dhcp_letter_required": {
      "type": "boolean"
    },
    "dhcp_letter_sent_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "Multi-source legal basis. Primary: 약사법 Article 73의2 (mandatory ADR reporting) and Article 73의3 (re-evaluation). Adjacent laws may include: 의약품 이상반응 보고 규정 (MFDS KGVP standards), ICH E2 series (clinical safety data management), EU GVP Modules (pharmacovigilance processes).",
      "examples": [
        [
          "약사법 Art.73의2",
          "KGVP 규정",
          "ICH E2A"
        ],
        [
          "약사법 Art.73의3",
          "EU GVP Module IX",
          "ICH E2E"
        ],
        [
          "약사법 Art.73의2",
          "KGVP 규정",
          "ICH E2B(R3)"
        ]
      ]
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
