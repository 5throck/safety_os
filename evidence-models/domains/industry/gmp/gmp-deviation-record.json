{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gmp-deviation-record.json",
  "title": "GMP Deviation Record",
  "description": "Evidence model for GMP Deviation (이상관리) records. v1 per KP-GMP 의약품등기준규정 Article 19 + ICH Q10.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "deviation_id",
    "classification",
    "description",
    "status",
    "legal_basis",
    "e_signature",
    "qrm_assessment",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GMP-DEV-[0-9]{4}-[0-9]{4}$"
    },
    "deviation_id": {
      "type": "string"
    },
    "classification": {
      "type": "string",
      "enum": [
        "minor",
        "major",
        "critical"
      ]
    },
    "deviation_type": {
      "type": "string",
      "enum": [
        "planned",
        "unplanned",
        "oos",
        "oot",
        "audit_finding"
      ]
    },
    "description": {
      "type": "string"
    },
    "discovered_at": {
      "type": "string",
      "format": "date-time"
    },
    "discovered_by": {
      "type": "string"
    },
    "immediate_action": {
      "type": "string"
    },
    "affected_batch": {
      "type": "string"
    },
    "affected_product": {
      "type": "string"
    },
    "investigation": {
      "type": "object",
      "properties": {
        "methodology": {
          "type": "string",
          "enum": [
            "5_whys",
            "fishbone",
            "FMEA",
            "FTA"
          ]
        },
        "root_cause": {
          "type": "string"
        },
        "contributing_causes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "investigator_id": {
          "type": "string"
        },
        "completion_date": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "capa_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^GMP-CAPA-[0-9]{4}-[0-9]{4}$"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "investigation",
        "capa_implementation",
        "effectiveness_check",
        "closed"
      ]
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "Multi-source legal basis. Primary: Pharmaceutical Affairs Act (약사법) Article 34 (GMP manufacturing obligation) and MFDS delegated legislation (의약품등기준규정). Adjacent laws may include: ICH Q7 (API GMP), ICH Q9 (Quality Risk Management), ICH Q10 (Pharmaceutical Quality System), PIC/S PE 009 (harmonized GMP).",
      "examples": [
        [
          "약사법 Art.34",
          "의약품등기준규정 Art.12",
          "ICH Q7"
        ],
        [
          "약사법 Art.34",
          "의약품등기준규정 Art.16",
          "ICH Q10"
        ],
        [
          "약사법 Art.34",
          "PIC/S PE 009-1",
          "ICH Q9"
        ]
      ]
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "qrm_assessment": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/qrm_assessment"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
