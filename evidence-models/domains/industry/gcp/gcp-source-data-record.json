{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gcp-source-data-record.json",
  "title": "GCP Source Data Record (ALCOA+)",
  "description": "Source documents per ICH E6(R3) Section 9 with ALCOA+ integrity.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "irb_approval_ref", "ich_e6_compliance", "protocol_ref", "site_id", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GCP-SD-[0-9]{4}-[0-9]{4}$" },
    "irb_approval_ref": {
      "type": ["string", "null"],
      "description": "IRB approval record ID"
    },
    "ich_e6_compliance": {
      "type": "boolean",
      "description": "Compliant with ICH E6(R3)"
    },
    "protocol_ref": {
      "type": "string",
      "description": "Study protocol record reference"
    },
    "site_id": {
      "type": "string",
      "description": "Investigational site identifier"
    },
    "source_document_type": { "type": "string", "enum": ["medical_record", "lab_report", "ecg", "icf", "randomization_record", "ip_accountability", "diary"] },
    "participant_id": { "type": "string" },
    "document_date": { "type": "string", "format": "date-time" },
    "location": { "type": "string", "description": "Physical or system location" },
    "format": { "type": "string", "enum": ["paper", "electronic", "hybrid"] },
    "alcoa_compliance": {
      "type": "object",
      "properties": {
        "attributable": { "type": "boolean" },
        "legible": { "type": "boolean" },
        "contemporaneous": { "type": "boolean" },
        "original": { "type": "boolean" },
        "accurate": { "type": "boolean" },
        "complete": { "type": "boolean" },
        "consistent": { "type": "boolean" },
        "enduring": { "type": "boolean" },
        "available": { "type": "boolean" }
      }
    },
    "sdv_status": { "type": "string", "enum": ["pending", "verified", "discrepancy", "not_applicable"] },
    "sdv_performed_by": { "type": ["string", "null"] },
    "sdv_date": { "type": ["string", "null"], "format": "date-time" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
