{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gcp-protocol-record.json",
  "title": "GCP Protocol Record",
  "description": "Clinical trial protocol per ICH E6(R3) Section 3.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "irb_approval_ref", "ich_e6_compliance", "protocol_ref", "site_id", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GCP-PROT-[0-9]{4}-[0-9]{4}$" },
    "irb_approval_ref": {
      "type": ["string", "null"],
      "description": "IRB approval record ID"
    },
    "ich_e6_compliance": {
      "type": "boolean",
      "description": "Compliant with ICH E6(R3)"
    },
    "protocol_ref": {
      "type": "string",
      "description": "Study protocol record reference"
    },
    "site_id": {
      "type": "string",
      "description": "Investigational site identifier"
    },
    "study_number": { "type": "string" },
    "study_title": { "type": "string" },
    "phase": { "type": "string", "enum": ["phase_1", "phase_2", "phase_3", "phase_4", "be"] },
    "sponsor_id": { "type": "string" },
    "principal_investigator_id": { "type": "string" },
    "investigator_brochure_version": { "type": "string" },
    "protocol_version": { "type": "string" },
    "amendment_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "amendment_id": { "type": "string" },
          "version": { "type": "string" },
          "date": { "type": "string", "format": "date-time" },
          "rationale": { "type": "string" },
          "irb_approval_ref": { "type": "string" }
        }
      }
    },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
