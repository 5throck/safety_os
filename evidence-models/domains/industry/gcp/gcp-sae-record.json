{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gcp-sae-record.json",
  "title": "GCP SAE Record",
  "description": "Serious Adverse Event reporting per KGCP Article 73의2 + ICH E2A.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "irb_approval_ref",
    "ich_e6_compliance",
    "protocol_ref",
    "site_id",
    "legal_basis",
    "e_signature",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GCP-SAE-[0-9]{4}-[0-9]{4}$"
    },
    "irb_approval_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "IRB approval record ID"
    },
    "ich_e6_compliance": {
      "type": "boolean",
      "description": "Compliant with ICH E6(R3)"
    },
    "protocol_ref": {
      "type": "string",
      "description": "Study protocol record reference"
    },
    "site_id": {
      "type": "string",
      "description": "Investigational site identifier"
    },
    "sae_id": {
      "type": "string"
    },
    "participant_id": {
      "type": "string"
    },
    "ip_batch_id": {
      "type": "string"
    },
    "event_term": {
      "type": "string",
      "description": "MedDRA Preferred Term"
    },
    "onset_date": {
      "type": "string",
      "format": "date"
    },
    "event_description": {
      "type": "string"
    },
    "seriousness_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "death",
          "life_threatening",
          "hospitalization",
          "disability",
          "congenital_anomaly",
          "other_serious"
        ]
      }
    },
    "causality_assessment": {
      "type": "object",
      "properties": {
        "investigator_assessment": {
          "type": "string",
          "enum": [
            "related",
            "possibly_related",
            "not_related",
            "not_assessable"
          ]
        },
        "sponsor_assessment": {
          "type": "string",
          "enum": [
            "related",
            "possibly_related",
            "not_related",
            "not_assessable"
          ]
        },
        "assessment_method": {
          "type": "string",
          "enum": [
            "global_intensity",
            "e.g._algo",
            "imPACT",
            "other"
          ]
        }
      }
    },
    "expectedness": {
      "type": "string",
      "enum": [
        "expected",
        "unexpected"
      ]
    },
    "susar": {
      "type": "boolean",
      "description": "Suspected Unexpected SAE — both unexpected and related"
    },
    "reporting_timeline": {
      "type": "object",
      "properties": {
        "fatal_susar_due_days": {
          "type": "integer",
          "default": 7
        },
        "other_serious_susar_due_days": {
          "type": "integer",
          "default": 15
        },
        "mfds_submitted_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "irb_notified_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "sponsor_notified_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "outcome": {
      "type": "string",
      "enum": [
        "recovered",
        "recovering",
        "not_recovered",
        "fatal",
        "unknown"
      ]
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "Multi-source legal basis. Primary: 약사법 Article 69 (clinical trial application) and Article 73의2 (SAE reporting). Adjacent laws may include: 생명윤리법 (Bioethics Act — IRB, informed consent), ICH E6(R3) (international GCP standard), Declaration of Helsinki (ethical principles).",
      "examples": [
        [
          "약사법 Art.69",
          "생명윤리법 Art.16",
          "ICH E6(R3)"
        ],
        [
          "약사법 Art.73의2",
          "ICH E6(R3) §5",
          "Declaration of Helsinki"
        ],
        [
          "약사법 Art.69",
          "ICH E6(R3) §8",
          "생명윤리법 Art.13"
        ]
      ]
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
