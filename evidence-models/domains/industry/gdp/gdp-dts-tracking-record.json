{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gdp-dts-tracking-record.json",
  "title": "GDP DTS Tracking Record",
  "description": "DTS (Drug Tracking System) compliance record per MFDS DTS regulations.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "legal_basis",
    "gdp_certification_status",
    "temperature_condition",
    "e_signature",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GDP-DTS-[0-9]{4}-[0-9]{4}$"
    },
    "gdp_certification_status": {
      "type": "string",
      "enum": [
        "certified",
        "pending",
        "suspended",
        "expired"
      ],
      "description": "KGDP certification status at time of record"
    },
    "temperature_condition": {
      "type": "string",
      "enum": [
        "cold_chain_2_8C",
        "frozen_below_minus_15C",
        "controlled_room_15_25C",
        "ambient_30C_max",
        "not_applicable"
      ]
    },
    "batch_disposition_approved_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "GMP batch-record ID (for goods receipt from manufacturing)"
    },
    "dts_code": {
      "type": "string",
      "description": "GS1 DataMatrix or RFID code"
    },
    "gtin": {
      "type": "string",
      "description": "Global Trade Item Number"
    },
    "batch_id": {
      "type": "string"
    },
    "product_code": {
      "type": "string"
    },
    "distribution_stage": {
      "type": "string",
      "enum": [
        "manufacturer_to_wholesaler",
        "wholesaler_to_pharmacy",
        "pharmacy_to_patient"
      ]
    },
    "transaction_date": {
      "type": "string",
      "format": "date-time"
    },
    "business_registration_number": {
      "type": "string"
    },
    "mfds_submission_status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending",
        "failed",
        "not_applicable"
      ]
    },
    "verification_result": {
      "type": "string",
      "enum": [
        "matched",
        "mismatched",
        "pending"
      ]
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "Multi-source legal basis. Primary: 약사법 Article 43의2 (distribution management obligation) and Article 43의3 (recall duty). Adjacent laws may include: 의약품 유통관리 기준 (MFDS KGDP standards), PIC/S GDP PE 009 (harmonized GDP), EU GDP 2013/C 343/01 (reference framework).",
      "examples": [
        [
          "약사법 Art.43의2",
          "KGDP 기준",
          "PIC/S GDP PE 009"
        ],
        [
          "약사법 Art.43의3",
          "EU GDP 2013/C 343/01",
          "KGDP 기준"
        ],
        [
          "약사법 Art.43의2",
          "KGDP DTS 규정",
          "PIC/S GDP PE 009"
        ]
      ]
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
