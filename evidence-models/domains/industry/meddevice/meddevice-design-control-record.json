{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "meddevice-design-control-record.json",
  "title": "Medical Device Design Control Record",
  "description": "ISO 13485 §7.3 design control.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "device_class",
    "kgmp_certification_status",
    "iso_13485_compliance",
    "legal_basis",
    "e_signature",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^MDDEV-DC-[0-9]{4}-[0-9]{4}$"
    },
    "device_class": {
      "type": "string",
      "enum": [
        "class_1",
        "class_2",
        "class_3",
        "class_4"
      ]
    },
    "kgmp_certification_status": {
      "type": "string",
      "enum": [
        "certified",
        "pending",
        "expired"
      ]
    },
    "iso_13485_compliance": {
      "type": "boolean"
    },
    "iso_14971_risk_management": {
      "type": "boolean"
    },
    "device_id": {
      "type": "string"
    },
    "design_project_id": {
      "type": "string"
    },
    "design_inputs_defined": {
      "type": "boolean"
    },
    "design_outputs_defined": {
      "type": "boolean"
    },
    "design_review_completed": {
      "type": "boolean"
    },
    "design_verification_completed": {
      "type": "boolean"
    },
    "design_validation_completed": {
      "type": "boolean"
    },
    "design_transfer_completed": {
      "type": "boolean"
    },
    "design_changes_controlled": {
      "type": "boolean"
    },
    "design_history_file_ref": {
      "type": "string"
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "Multi-source legal basis. Primary: 의료기기법 Articles 12/16/20/23 (device registration, manufacturing, clinical trials, labeling). Adjacent laws may include: 의료기기 제조 및 품질관리 기준 (KGMP-MD / MFDS 고시), ISO 13485 (QMS), ISO 14971 (Risk Management), EU MDR 2017/745, FDA QSR 21 CFR 820.",
      "examples": [
        [
          "의료기기법 Art.16",
          "KGMP-MD",
          "ISO 13485"
        ],
        [
          "의료기기법 Art.20",
          "ISO 14971",
          "KGMP-MD"
        ],
        [
          "의료기기법 Art.12",
          "EU MDR 2017/745",
          "ISO 14971"
        ]
      ]
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
