{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "meddevice-labeling-record.json",
  "title": "Medical Device Labeling Record",
  "description": "Device labeling per 의료기기법 Article 23.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "device_class", "kgmp_certification_status", "iso_13485_compliance", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^MDDEV-LBL-[0-9]{4}-[0-9]{4}$" },
    "device_class": { "type": "string", "enum": ["class_1", "class_2", "class_3", "class_4"] },
    "kgmp_certification_status": { "type": "string", "enum": ["certified", "pending", "expired"] },
    "iso_13485_compliance": { "type": "boolean" },
    "iso_14971_risk_management": { "type": "boolean" },
    "device_id": { "type": "string" },
    "label_version": { "type": "string" },
    "ifu_language": { "type": "string", "description": "ISO 639-1" },
    "label_elements": { "type": "array", "items": { "type": "string", "enum": ["device_name", "manufacturer", "lot_batch", "expiry", "storage", "warnings", "instructions", "udi", "ce_mark", "kfda_mark"] } },
    "udi_assigned": { "type": "boolean" },
    "advertising_compliant": { "type": "boolean" },

    "legal_basis": { "type": "array", "items": { "type": "string" }, "minItems": 3 },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
