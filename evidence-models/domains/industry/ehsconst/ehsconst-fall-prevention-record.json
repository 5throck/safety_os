{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ehsconst-fall-prevention-record.json",
  "title": "Construction Fall Prevention Record",
  "description": "추락 방지 조치 기록 — 사망사고 원인 1위 (~42%).",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "sapa_article_12_compliance", "project_id", "contractor_tier", "safety_officer_in_charge", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^EHSC-FALL-[0-9]{4}-[0-9]{4}$" },
    "sapa_article_12_compliance": {
      "type": "boolean",
      "description": "중대재해처벌법 Article 12 (건설업 특례) 준수"
    },
    "project_id": {
      "type": "string",
      "description": "건설공사 번호 (Construction project number)"
    },
    "contractor_tier": {
      "type": "string",
      "enum": ["ordering_party", "prime_contractor", "first_subcontractor", "second_subcontractor_below"],
      "description": "발주처/원도급/1차 하도급/2차 이하"
    },
    "safety_officer_in_charge": {
      "type": "string",
      "description": "안전관리자 ID"
    },
    "work_area": { "type": "string" },
    "work_height_m": { "type": "number", "description": "2m 이상 시 추락 방지 의무" },
    "fall_protection_hierarchy": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": { "type": "string", "enum": ["elimination", "passive_guardrail", "safety_net", "active_harness", "admin_control", "ppe"] },
          "implemented": { "type": "boolean" }
        }
      }
    },
    "guardrail_installed": { "type": "boolean" },
    "safety_net_installed": { "type": "boolean" },
    "harness_anchor_points": { "type": "integer" },
    "workers_equipped_with_harness": { "type": "integer" },
    "rescue_plan_ref": { "type": ["string", "null"] },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
