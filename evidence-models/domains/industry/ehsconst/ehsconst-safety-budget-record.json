{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ehsconst-safety-budget-record.json",
  "title": "Construction Safety Budget Execution Record",
  "description": "안전관리비 집행 증빙 per 산업안전보건법 Article 17.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "sapa_article_12_compliance", "project_id", "contractor_tier", "safety_officer_in_charge", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^EHSC-BUD-[0-9]{4}-[0-9]{4}$" },
    "sapa_article_12_compliance": {
      "type": "boolean",
      "description": "중대재해처벌법 Article 12 (건설업 특례) 준수"
    },
    "project_id": {
      "type": "string",
      "description": "건설공사 번호 (Construction project number)"
    },
    "contractor_tier": {
      "type": "string",
      "enum": ["ordering_party", "prime_contractor", "first_subcontractor", "second_subcontractor_below"],
      "description": "발주처/원도급/1차 하도급/2차 이하"
    },
    "safety_officer_in_charge": {
      "type": "string",
      "description": "안전관리자 ID"
    },
    "budget_period": {
      "type": "object",
      "properties": {
        "fiscal_year": { "type": "integer" },
        "quarter": { "type": ["string", "null"] }
      }
    },
    "total_budget_krw": { "type": "number" },
    "executed_amount_krw": { "type": "number" },
    "execution_rate_pct": { "type": "number" },
    "legal_minimum_rate_pct": { "type": "number", "description": "1.5% (일반) / 5.0% (고위험)" },
    "category_breakdown": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string", "enum": ["safety_equipment", "safety_education", "safety_inspection", "health_examination", "safety_officer_labor", "ppe", "training_materials", "other"] },
          "budget_krw": { "type": "number" },
          "executed_krw": { "type": "number" },
          "supporting_documents": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "audit_status": { "type": "string", "enum": ["pending", "under_review", "approved", "violations_found"] },
    "violations": { "type": "array", "items": { "type": "string" } },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
