{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glp-qau-inspection-record.json",
  "title": "GLP QAU Inspection Record",
  "description": "Quality Assurance Unit inspection per OECD GLP Section 3.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "study_director_id", "glp_certification_authority", "oecd_mad_applicable", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GLP-QAU-[0-9]{4}-[0-9]{4}$" },
    "study_director_id": {
      "type": "string",
      "description": "OECD GLP requires designated Study Director (Section 1.2)"
    },
    "glp_certification_authority": {
      "type": "string",
      "enum": ["MFDS", "ME", "both", "OECD_MAD_only"],
      "description": "Which authority's GLP certification applies"
    },
    "oecd_mad_applicable": {
      "type": "boolean",
      "description": "Whether data is eligible for OECD Mutual Acceptance of Data"
    },
    "msds_record_ref": {
      "type": ["string", "null"],
      "description": "MSDS record ID for test article (when applicable)"
    },
    "inspection_id": { "type": "string" },
    "inspection_type": { "type": "string", "enum": ["facility", "study_based", "process_based", "for_cause"] },
    "scope": { "type": "string" },
    "inspection_date": { "type": "string", "format": "date-time" },
    "inspector_id": { "type": "string", "description": "QAU personnel — must be independent of study team" },
    "study_number_ref": { "type": ["string", "null"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "string" },
          "classification": { "type": "string", "enum": ["critical", "major", "minor", "observation"] },
          "description": { "type": "string" },
          "capa_ref": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "in_progress", "verified", "closed"] }
        }
      }
    },
    "report_to_study_director_date": { "type": "string", "format": "date-time" },
    "management_report_date": { "type": ["string", "null"], "format": "date-time" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
