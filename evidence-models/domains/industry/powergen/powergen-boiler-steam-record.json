{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "powergen-boiler-steam-record.json",
  "title": "Power Plant Boiler and Steam Record",
  "description": "화력 발전 보일러/증기 시스템 운영 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "record_id",
    "plant_type",
    "kesa_inspection_status",
    "voltage_class",
    "legal_basis",
    "e_signature",
    "nomenclature",
    "audit_trail"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^PWRG-BLR-[0-9]{4}-[0-9]{4}$"
    },
    "plant_type": {
      "type": "string",
      "enum": [
        "thermal_coal",
        "thermal_LNG",
        "thermal_oil",
        "wind",
        "solar",
        "hydro",
        "geothermal",
        "biomass",
        "fuel_cell",
        "ess"
      ]
    },
    "kesa_inspection_status": {
      "type": "string",
      "enum": [
        "certified",
        "pending",
        "failed",
        "expired"
      ],
      "description": "한국전기안전공사 (KESCO) 인증 상태"
    },
    "voltage_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "extra_high",
        "not_applicable"
      ],
      "description": "low (≤400V) / medium (400V-22kV) / high (22-154kV) / extra_high (>154kV)"
    },
    "psm_applicable": {
      "type": "boolean",
      "description": "대규모 발전시설 (보일러/가스) PSM 적용 여부 (OSHA-KR Art 44)"
    },
    "renewable_category": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "wind",
        "solar",
        "hydro",
        "geothermal",
        "biomass",
        "fuel_cell",
        "ess",
        null
      ]
    },
    "facility_id": {
      "type": "string"
    },
    "boiler_id": {
      "type": "string"
    },
    "design_pressure_bar": {
      "type": "number"
    },
    "operating_pressure_bar": {
      "type": "number"
    },
    "steam_temperature_c": {
      "type": "number"
    },
    "steam_flow_tph": {
      "type": "number",
      "description": "tons per hour"
    },
    "fuel_type": {
      "type": "string",
      "enum": [
        "coal",
        "LNG",
        "oil",
        "biomass"
      ]
    },
    "safety_relief_valve_count": {
      "type": "integer"
    },
    "water_treatment_compliant": {
      "type": "boolean"
    },
    "blowdown_executed": {
      "type": "boolean"
    },
    "last_hydrotest_date": {
      "type": "string",
      "format": "date"
    },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "e_signature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature"
    },
    "nomenclature": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature"
    },
    "audit_trail": {
      "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail"
    }
  }
}
