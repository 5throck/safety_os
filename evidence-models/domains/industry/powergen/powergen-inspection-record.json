{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "powergen-inspection-record.json",
  "title": "Power Plant Inspection Record",
  "description": "발전설비 정기 점검 기록 (KESCO 인증).",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "plant_type", "kesa_inspection_status", "voltage_class", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^PWRG-INSP-[0-9]{4}-[0-9]{4}$" },
    "plant_type": {
      "type": "string",
      "enum": ["thermal_coal", "thermal_LNG", "thermal_oil", "wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess"]
    },
    "kesa_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"],
      "description": "한국전기안전공사 (KESCO) 인증 상태"
    },
    "voltage_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "extra_high", "not_applicable"],
      "description": "low (≤400V) / medium (400V-22kV) / high (22-154kV) / extra_high (>154kV)"
    },
    "renewable_category": {
      "type": ["string", "null"],
      "enum": ["wind", "solar", "hydro", "geothermal", "biomass", "fuel_cell", "ess", null]
    },
    "facility_id": { "type": "string" },
    "inspection_type": { "type": "string", "enum": ["monthly_self", "quarterly_KESCO", "annual_comprehensive", "internal", "regulatory"] },
    "inspector_id": { "type": "string" },
    "inspection_date": { "type": "string", "format": "date-time" },
    "next_inspection_due": { "type": "string", "format": "date" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "string" },
          "category": { "type": "string", "enum": ["electrical", "mechanical", "structural", "instrumentation", "safety_system"] },
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "description": { "type": "string" },
          "corrective_action": { "type": "string" }
        }
      }
    },
    "result": { "type": "string", "enum": ["pass", "conditional_pass", "fail"] },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
