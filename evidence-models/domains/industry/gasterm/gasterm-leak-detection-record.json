{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gasterm-leak-detection-record.json",
  "title": "Gas Leak Detection and Response Record",
  "description": "가스 검지기 알람 및 대응 기록.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "facility_type", "kgs_inspection_status", "psm_applicable", "gas_type", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GTRM-LEAK-[0-9]{4}-[0-9]{4}$" },
    "facility_type": {
      "type": "string",
      "enum": ["LNG_terminal", "LPG_charging", "hydrogen_charging", "city_gas_storage", "pipe_transfer"]
    },
    "kgs_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"]
    },
    "psm_applicable": {
      "type": "boolean",
      "description": "대규모 가스터미널 PSM 적용 여부"
    },
    "gas_type": {
      "type": "string",
      "enum": ["LNG", "LPG", "hydrogen", "natural_gas", "other"]
    },
    "facility_id": { "type": "string" },
    "detector_id": { "type": "string" },
    "detector_location": { "type": "string" },
    "alarm_threshold_ppm": { "type": "number" },
    "concentration_measured_ppm": { "type": "number" },
    "lel_pct": { "type": "number", "description": "Lower Explosive Limit %" },
    "alarm_triggered_at": { "type": "string", "format": "date-time" },
    "response_action_taken": { "type": "string" },
    "source_isolated": { "type": "boolean" },
    "evacuation_executed": { "type": "boolean" },
    "ventilation_activated": { "type": "boolean" },
    "kgs_notified": { "type": "boolean" },
    "false_alarm": { "type": "boolean" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
