{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gasterm-emergency-preparedness-record.json",
  "title": "Gas Emergency Preparedness Record",
  "description": "비상 대비 (확산 모델, 대피 훈련).",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "facility_type", "kgs_inspection_status", "psm_applicable", "gas_type", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GTRM-PREP-[0-9]{4}-[0-9]{4}$" },
    "facility_type": {
      "type": "string",
      "enum": ["LNG_terminal", "LPG_charging", "hydrogen_charging", "city_gas_storage", "pipe_transfer"]
    },
    "kgs_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"]
    },
    "psm_applicable": {
      "type": "boolean",
      "description": "대규모 가스터미널 PSM 적용 여부"
    },
    "gas_type": {
      "type": "string",
      "enum": ["LNG", "LPG", "hydrogen", "natural_gas", "other"]
    },
    "facility_id": { "type": "string" },
    "drill_type": { "type": "string", "enum": ["leak_response", "explosion_response", "evacuation", "tabletop"] },
    "drill_date": { "type": "string", "format": "date" },
    "participants_count": { "type": "integer" },
    "scenario_description": { "type": "string" },
    "dispersion_model_used": { "type": ["string", "null"] },
    "evacuation_time_actual_min": { "type": "number" },
    "evacuation_time_target_min": { "type": "number" },
    "lessons_learned": { "type": "string" },
    "improvement_actions": { "type": "array", "items": { "type": "string" } },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
