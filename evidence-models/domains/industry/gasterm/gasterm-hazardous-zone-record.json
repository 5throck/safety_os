{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gasterm-hazardous-zone-record.json",
  "title": "Hazardous Zone Management Record",
  "description": "법정 위해 구역/거리 관리.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "facility_type", "kgs_inspection_status", "psm_applicable", "gas_type", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^GTRM-ZONE-[0-9]{4}-[0-9]{4}$" },
    "facility_type": {
      "type": "string",
      "enum": ["LNG_terminal", "LPG_charging", "hydrogen_charging", "city_gas_storage", "pipe_transfer"]
    },
    "kgs_inspection_status": {
      "type": "string",
      "enum": ["certified", "pending", "failed", "expired"]
    },
    "psm_applicable": {
      "type": "boolean",
      "description": "대규모 가스터미널 PSM 적용 여부"
    },
    "gas_type": {
      "type": "string",
      "enum": ["LNG", "LPG", "hydrogen", "natural_gas", "other"]
    },
    "facility_id": { "type": "string" },
    "zone_survey_date": { "type": "string", "format": "date" },
    "legal_distance_required_m": { "type": "number" },
    "actual_distance_to_nearest_building_m": { "type": "number" },
    "nearest_building_type": { "type": "string", "enum": ["school", "hospital", "residential", "commercial", "industrial"] },
    "compliance_status": { "type": "string", "enum": ["compliant", "violation", "variance_required"] },
    "variance_obtained": { "type": ["boolean", "null"] },
    "monitoring_devices_count": { "type": "integer" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../../../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../../../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
