{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gmp-self-inspection-record.json",
  "title": "GMP Self-Inspection Record",
  "description": "Evidence model for GMP Self-Inspection (자체점검) records. v1 per KP-GMP 의약품등기준규정 Article 15 + PIC/S PE 009 Chapter 9. Includes risk-based frequency adjustment per meeting 2026-06-17.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "inspection_id", "scope", "frequency", "findings_count", "status", "legal_basis", "e_signature", "qrm_assessment", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GMP-SI-[0-9]{4}-[0-9]{4}$"
    },
    "inspection_id": { "type": "string" },
    "scope": { "type": "string" },
    "area_category": {
      "type": "string",
      "enum": ["high_risk", "medium_risk", "low_risk"]
    },
    "frequency": {
      "type": "object",
      "properties": {
        "default": { "type": "string", "enum": ["annual"] },
        "applied": { "type": "string", "enum": ["quarterly", "semi-annual", "annual"] },
        "risk_based_adjustment": {
          "type": "object",
          "properties": {
            "high_risk_areas": { "type": "string", "enum": ["quarterly"] },
            "medium_risk_areas": { "type": "string", "enum": ["semi-annual"] },
            "low_risk_areas": { "type": "string", "enum": ["annual"] }
          }
        },
        "risk_classification_logic": { "type": "string" },
        "last_inspection": { "type": "string", "format": "date-time" },
        "next_due": { "type": "string", "format": "date-time" }
      }
    },
    "inspection_team": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inspection_date": { "type": "string", "format": "date-time" },
    "findings_count": { "type": "integer" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "string" },
          "classification": { "type": "string", "enum": ["critical", "major", "minor", "observation"] },
          "description": { "type": "string" },
          "capa_ref": { "type": "string", "pattern": "^GMP-CAPA-[0-9]{4}-[0-9]{4}$" }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "completed", "closed"]
    },
    "management_review_date": { "type": "string", "format": "date-time" },
    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "e_signature": { "$ref": "base/gmp-common.schema.json#/definitions/e_signature" },
    "qrm_assessment": { "$ref": "base/gmp-common.schema.json#/definitions/qrm_assessment" },
    "nomenclature": { "$ref": "base/gmp-common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "base/gmp-common.schema.json#/definitions/audit_trail" }
  }
}
