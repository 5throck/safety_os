{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PSM PSI Record",
  "description": "Schema for logging Process Safety Information versions, MSDS identifiers, and approval history.",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "recordId": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "agentId": {
      "type": "string"
    },
    "workflowId": {
      "type": "string"
    },
    "legalBasis": {
      "type": "string",
      "enum": ["OSHA-KR Article 44"]
    },
    "documentType": {
      "type": "string",
      "enum": ["P&ID", "MSDS", "Process Chemistry", "Equipment Design", "Other"]
    },
    "msdsIdentifier": {
      "type": "string"
    },
    "documentVersion": {
      "type": "string"
    },
    "approvalHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "approverRole": {
            "type": "string"
          },
          "approvalDate": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["Approved", "Rejected", "Pending"]
          }
        },
        "required": ["approverRole", "approvalDate", "status"]
      }
    }
  },
  "required": ["recordId", "timestamp", "agentId", "workflowId", "legalBasis", "documentType", "documentVersion", "approvalHistory"]
}
