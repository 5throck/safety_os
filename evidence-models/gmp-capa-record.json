{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gmp-capa-record.json",
  "title": "GMP CAPA Record",
  "description": "Evidence model for GMP Corrective and Preventive Action (CAPA, 시정예방조치) records. v1 per KP-GMP 의약품등기준규정 Article 19 + ICH Q10.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "capa_id", "source_deviation", "action_type", "status", "legal_basis", "e_signature", "qrm_assessment", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^GMP-CAPA-[0-9]{4}-[0-9]{4}$"
    },
    "capa_id": { "type": "string" },
    "source_deviation": {
      "type": "string",
      "pattern": "^GMP-DEV-[0-9]{4}-[0-9]{4}$"
    },
    "action_type": {
      "type": "string",
      "enum": ["corrective", "preventive", "both"]
    },
    "description": { "type": "string" },
    "action_plan": { "type": "string" },
    "owner_id": { "type": "string" },
    "target_date": { "type": "string", "format": "date-time" },
    "implementation_date": { "type": "string", "format": "date-time" },
    "effectiveness_check": {
      "type": "object",
      "properties": {
        "method": { "type": "string" },
        "criteria": { "type": "string" },
        "due_date": { "type": "string", "format": "date-time" },
        "result": { "type": "string", "enum": ["effective", "ineffective", "pending"] }
      }
    },
    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "implemented", "effectiveness_check", "closed", "overdue"]
    },
    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "e_signature": { "$ref": "base/gmp-common.schema.json#/definitions/e_signature" },
    "qrm_assessment": { "$ref": "base/gmp-common.schema.json#/definitions/qrm_assessment" },
    "nomenclature": { "$ref": "base/gmp-common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "base/gmp-common.schema.json#/definitions/audit_trail" }
  }
}
