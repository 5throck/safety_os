{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "emergency-electrical-record.json",
  "title": "Emergency Electrical Incident Record",
  "description": "Electrical shock, electrocution, electrical fire response.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "incident_id", "incident_type", "severity", "response_status", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^EMRG-ELEC-[0-9]{4}-[0-9]{4}$" },
    "incident_id": { "type": "string", "description": "Unique incident identifier" },
    "incident_type": {
      "type": "string",
      "enum": ["electric_shock", "electrocution", "arc_flash", "electrical_fire", "power_outage_critical"]
    },
    "severity": {
      "type": "string",
      "enum": ["minor", "moderate", "serious", "critical", "fatal"]
    },
    "incident_datetime": { "type": "string", "format": "date-time" },
    "location": { "type": "string" },
    "casualties": {
      "type": "object",
      "properties": {
        "fatalities": { "type": "integer", "default": 0 },
        "serious_injuries": { "type": "integer", "default": 0 },
        "minor_injuries": { "type": "integer", "default": 0 },
        "missing": { "type": "integer", "default": 0 }
      }
    },
    "response_status": {
      "type": "string",
      "enum": ["reported", "active_response", "contained", "resolved", "under_investigation", "closed"]
    },
    "sapa_qualifying": { "type": "boolean", "description": "중대재해처벌법 적용 여부" },
    "voltage_level": { "type": "string", "enum": ["low_220v", "medium_380v", "high_3kv_above", "transmission"] },
    "current_path": { "type": ["string", "null"], "description": "Entry/exit points in body" },
    "power_isolated_by": { "type": "string" },
    "power_isolated_at": { "type": "string", "format": "date-time" },
    "cpr_required": { "type": "boolean" },
    "burn_severity": { "type": "string", "enum": ["none", "first_degree", "second_degree", "third_degree"] },
    "victim_id": { "type": ["string", "null"] },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "e_signature": { "$ref": "../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
