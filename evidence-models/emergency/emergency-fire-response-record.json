{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "emergency-fire-response-record.json",
  "title": "Emergency Fire Response Record",
  "description": "Fire/explosion incident response (discovery, evacuation, suppression, scene preservation).",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "incident_id", "incident_type", "severity", "response_status", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^EMRG-FIRE-[0-9]{4}-[0-9]{4}$" },
    "incident_id": { "type": "string", "description": "Unique incident identifier" },
    "incident_type": {
      "type": "string",
      "enum": ["structural_fire", "equipment_fire", "chemical_fire", "electrical_fire", "wildland_fire", "other"]
    },
    "severity": {
      "type": "string",
      "enum": ["minor", "moderate", "serious", "critical", "fatal"]
    },
    "incident_datetime": { "type": "string", "format": "date-time" },
    "location": { "type": "string" },
    "casualties": {
      "type": "object",
      "properties": {
        "fatalities": { "type": "integer", "default": 0 },
        "serious_injuries": { "type": "integer", "default": 0 },
        "minor_injuries": { "type": "integer", "default": 0 },
        "missing": { "type": "integer", "default": 0 }
      }
    },
    "response_status": {
      "type": "string",
      "enum": ["reported", "active_response", "contained", "resolved", "under_investigation", "closed"]
    },
    "sapa_qualifying": { "type": "boolean", "description": "중대재해처벌법 적용 여부" },
    "fire_source": { "type": "string" },
    "initial_suppression_attempted": { "type": "boolean" },
    "initial_suppression_successful": { "type": "boolean" },
    "external_fire_department_dispatched": { "type": "boolean" },
    "external_dispatch_datetime": { "type": ["string", "null"], "format": "date-time" },
    "evacuation_completed": { "type": "boolean" },
    "evacuation_duration_minutes": { "type": "integer" },
    "scene_preserved_for_investigation": { "type": "boolean" },
    "incident_investigation_agent_dispatched": { "type": "boolean", "description": "Handoff confirmation per emergency-agent.md §Handoff Protocols" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
