{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "emergency-chemical-release-record.json",
  "title": "Emergency Chemical Release Response Record",
  "description": "Chemical substance leak/release response. Links to MSDS domain.",
  "version": "1.0.0",
  "type": "object",
  "required": ["record_id", "incident_id", "incident_type", "severity", "response_status", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^EMRG-CHEM-[0-9]{4}-[0-9]{4}$" },
    "incident_id": { "type": "string", "description": "Unique incident identifier" },
    "incident_type": {
      "type": "string",
      "enum": ["gas_leak", "liquid_spill", "dust_release", "vapor_release", "explosive_release"]
    },
    "severity": {
      "type": "string",
      "enum": ["minor", "moderate", "serious", "critical", "fatal"]
    },
    "incident_datetime": { "type": "string", "format": "date-time" },
    "location": { "type": "string" },
    "casualties": {
      "type": "object",
      "properties": {
        "fatalities": { "type": "integer", "default": 0 },
        "serious_injuries": { "type": "integer", "default": 0 },
        "minor_injuries": { "type": "integer", "default": 0 },
        "missing": { "type": "integer", "default": 0 }
      }
    },
    "response_status": {
      "type": "string",
      "enum": ["reported", "active_response", "contained", "resolved", "under_investigation", "closed"]
    },
    "sapa_qualifying": { "type": "boolean", "description": "중대재해처벌법 적용 여부" },
    "chemical_name": { "type": "string" },
    "msds_record_ref": { "type": ["string", "null"], "description": "MSDS record ID for the chemical" },
    "cas_number": { "type": ["string", "null"] },
    "quantity_released": { "type": "string", "description": "Amount + unit" },
    "containment_zone_radius_m": { "type": "number" },
    "evacuation_executed": { "type": "boolean" },
    "environmental_report_filed": { "type": "boolean" },
    "ppe_used_by_responders": { "type": "array", "items": { "type": "string" } },
    "cleanup_completed": { "type": "boolean" },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "e_signature": { "$ref": "../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
