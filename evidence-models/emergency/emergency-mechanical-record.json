{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "emergency-mechanical-record.json",
  "title": "Emergency Mechanical Accident Record",
  "description": "Mechanical accident response (caught-in, crushing, laceration).",
  "version": "1.1.0",
  "type": "object",
  "required": ["record_id", "incident_id", "incident_type", "severity", "response_status", "legal_basis", "e_signature", "nomenclature", "audit_trail"],
  "properties": {
    "record_id": { "type": "string", "pattern": "^EMRG-MECH-[0-9]{4}-[0-9]{4}$" },
    "incident_id": { "type": "string", "description": "Unique incident identifier" },
    "incident_type": {
      "type": "string",
      "enum": ["caught_in", "crush_injury", "severe_laceration", "amputation", "rotary_entanglement", "falling_object"]
    },
    "severity": {
      "type": "string",
      "enum": ["minor", "moderate", "serious", "critical", "fatal"]
    },
    "incident_datetime": { "type": "string", "format": "date-time" },
    "location": { "type": "string" },
    "casualties": {
      "type": "object",
      "properties": {
        "fatalities": { "type": "integer", "default": 0 },
        "serious_injuries": { "type": "integer", "default": 0 },
        "minor_injuries": { "type": "integer", "default": 0 },
        "missing": { "type": "integer", "default": 0 }
      }
    },
    "response_status": {
      "type": "string",
      "enum": ["reported", "active_response", "contained", "resolved", "under_investigation", "closed"]
    },
    "sapa_qualifying": { "type": "boolean", "description": "중대재해처벌법 적용 여부" },
    "machine_id": { "type": "string" },
    "machine_type": { "type": "string", "enum": ["press", "conveyor", "lathe", "crane", "forklift", "robotic_arm", "other"] },
    "emergency_stop_activated": { "type": "boolean" },
    "extraction_method": { "type": "string", "enum": ["machine_dismantling", "mechanical_lift", "cutting", "manual", "other"] },
    "extraction_duration_minutes": { "type": "integer" },
    "amputation_involved": { "type": "boolean" },
    "amputated_part_preserved": { "type": ["boolean", "null"], "description": "For reattachment" },
    "hospital_destination": { "type": ["string", "null"] },

    "legal_basis": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "e_signature": { "$ref": "../_shared/base/common.schema.json#/definitions/e_signature" },
    "nomenclature": { "$ref": "../_shared/base/common.schema.json#/definitions/nomenclature" },
    "audit_trail": { "$ref": "../_shared/base/common.schema.json#/definitions/audit_trail" }
  }
}
