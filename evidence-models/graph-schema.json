{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Safety OS Knowledge Graph Schema",
  "description": "Schema definition for the 8 core nodes in the Safety OS Knowledge Graph.",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "properties"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the node"
          },
          "type": {
            "type": "string",
            "enum": [
              "Regulation",
              "Requirement",
              "Control",
              "Workflow",
              "Incident",
              "IndustryProfile",
              "Worker",
              "TrainingRecord"
            ]
          },
          "properties": {
            "type": "object",
            "description": "Node-specific properties"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "relationship"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "relationship": { "type": "string" }
        }
      }
    }
  }
}
